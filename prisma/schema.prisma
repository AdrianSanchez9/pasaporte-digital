generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  nombre    String
  apellido  String
  email     String   @unique
  password  String
  activo    Boolean  @default(true)
  rolId     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  rol              Role           @relation(fields: [rolId], references: [id])
  refreshTokens    RefreshToken[]
  datosPaciente    Paciente?
  datosMedico      Medico?
  datosAcompanante Acompanante?

  @@index([email])
  @@index([rolId])
}

// ─── Modelo de Rol ────────────────────────────────────────────────────────────
model Role {
  id          String   @id @default(uuid())
  nombre      String   @unique // "PACIENTE", "MEDICO", "ACOMPANANTE", "USUARIO_EXTERNO", "ADMIN"
  descripcion String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  users    User[]
  permisos RolePermission[]

  @@index([nombre])
}

// ─── Modelo de Permiso ────────────────────────────────────────────────────────
model Permission {
  id          String   @id @default(uuid())
  accion      String   @unique // "ver_pacientes", "editar_paciente", etc.
  descripcion String?  @db.Text
  modulo      String? // "pacientes", "usuarios", "sistema" (para agrupar en UI)
  createdAt   DateTime @default(now())

  // Relaciones
  roles RolePermission[]

  @@index([accion])
  @@index([modulo])
}

// ─── Tabla intermedia: Roles <-> Permisos (N:N) ──────────────────────────────
model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

// ─── Modelo de Paciente ───────────────────────────────────────────────────────
model Paciente {
  userId                String        @id
  dni                   String?
  apodo                 String?
  nroObraSocial         String?
  fechaNacimiento       DateTime?
  direccion             String?       @db.Text
  telefono              String?
  medicoCabeceraId      String?             // FK hacia MedicoCabecera (opcional)
  necesidadesReligiosas String?       @db.Text
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactos ContactoPaciente[]
  medicoCabecera        MedicoCabecera?     @relation(fields: [medicoCabeceraId], references: [id])
  acompanantes  Acompanante[]
}

model ContactoPaciente {
  id          String   @id @default(uuid())
  nombre      String
  telefono    String?
  direccion   String?  @db.Text
  relacion    String?
  pacienteId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  paciente Paciente[]

  @@index([pacienteId])
}

model MedicoCabecera {
  id         String   @id @default(uuid())
  nombre     String
  apellido   String
  telefono   String?
  direccion  String?  @db.Text
  pacienteId String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  paciente Paciente[]

  @@index([pacienteId])
}

// ─── Modelo de Médico ─────────────────────────────────────────────────────────
model Medico {
  userId String   @id
  especialidad String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Modelo de Acompañante ────────────────────────────────────────────────────
model Acompanante {
  userId      String   @id
  pacienteId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  paciente Paciente @relation(fields: [pacienteId], references: [userId], onDelete: Cascade)

  @@index([pacienteId])
}

// ─── Modelo de RefreshToken (JWT) ─────────────────────────────────────────────
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique @db.VarChar(512)
  userId    String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}
