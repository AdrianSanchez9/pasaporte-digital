generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  nombre    String
  apellido  String
  email     String   @unique
  password  String
  activo    Boolean  @default(true)
  rolId     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  rol              Role           @relation(fields: [rolId], references: [id])
  refreshTokens    RefreshToken[]
  datosPaciente    Paciente?
  datosMedico      Medico?
  datosAcompanante Acompanante?

  @@index([email])
  @@index([rolId])
}

// ─── Modelo de Rol ────────────────────────────────────────────────────────────
model Role {
  id          String   @id @default(uuid())
  nombre      String   @unique // "PACIENTE", "MEDICO", "ACOMPANANTE", "USUARIO_EXTERNO", "ADMIN"
  descripcion String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  users    User[]
  permisos RolePermission[]

  @@index([nombre])
}

// ─── Modelo de Permiso ────────────────────────────────────────────────────────
model Permission {
  id          String   @id @default(uuid())
  accion      String   @unique // "ver_pacientes", "editar_paciente", etc.
  descripcion String?  @db.Text
  modulo      String? // "pacientes", "usuarios", "sistema" (para agrupar en UI)
  createdAt   DateTime @default(now())

  // Relaciones
  roles RolePermission[]

  @@index([accion])
  @@index([modulo])
}

// ─── Tabla intermedia: Roles <-> Permisos (N:N) ──────────────────────────────
model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

// ─── Modelo de Paciente ───────────────────────────────────────────────────────
model Paciente {
  userId                String        @id
  dni                   String?
  apodo                 String?
  nroObraSocial         String?
  fechaNacimiento       DateTime?
  direccion             String?       @db.Text
  telefono              String?
  medicoCabeceraId      String?
  religion              String?
  fotoPerfil            String?
  necesidadesReligiosas String?       @db.Text
  nacionalidad          String?       @db.Text
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactos ContactoPaciente[]
  medicoCabecera        MedicoCabecera?     @relation(fields: [medicoCabeceraId], references: [id])
  acompanantes  Acompanante[]
  historial  HistorialPaciente?
  cuidadoPersonal       CuidadoPersonal?
  perfilComunicacion    PerfilComunicacion?
  emociones             EmocionesGustos?

  @@index([userId])

}

model ContactoPaciente {
  id          String   @id @default(uuid())
  nombre      String
  telefono    String?
  direccion   String?  @db.Text
  relacion    String?
  pacienteId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  paciente Paciente @relation(fields: [pacienteId], references: [userId])

  @@index([pacienteId])
}

model MedicoCabecera {
  id         String   @id @default(uuid())
  nombre     String
  apellido   String
  telefono   String?
  direccion  String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  paciente Paciente[]

  @@index([nombre])
}

// ─── Modelo de Médico ─────────────────────────────────────────────────────────
model Medico {
  userId String   @id
  especialidad String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Modelo de Acompañante ────────────────────────────────────────────────────
model Acompanante {
  userId      String   @id
  pacienteId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  paciente Paciente @relation(fields: [pacienteId], references: [userId], onDelete: Cascade)

  @@index([pacienteId])
}

// ─── Modelo de RefreshToken (JWT) ─────────────────────────────────────────────
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique @db.VarChar(512)
  userId    String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}


model Medicamento {
  id                        String                     @id @default(uuid())
  nombre                    String                     @unique  // "Paracetamol", "Ibuprofeno"
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt

  informacionMedicamentos   InformacionMedicamento[]

  @@index([nombre])
}


// ─── Tabla Intermedia: Historial <-> Medicamento ─────────────────────────────
model InformacionMedicamento {
  id                      String            @id @default(uuid())
  historialId             String
  medicamentoId           String?
  medicamentoPersonalizado String?

  dosis                   String?
  horarios                String?
  formaMedicamento        String?
  tipoMedicamento         String?
  momentoIngesta          String?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  historial               HistorialPaciente @relation(fields: [historialId], references: [id], onDelete: Cascade)
  medicamento             Medicamento?      @relation(fields: [medicamentoId], references: [id])

  // Constraint: Debe tener AL MENOS UNO (medicamentoId O medicamentoPersonalizado)
  // No se puede hacer a nivel de Prisma, lo validamos en el controller

  @@index([historialId])
  @@index([medicamentoId])
}



model HistorialPaciente {
  id                    String                     @id @default(uuid())
  pacienteId            String                     @unique  // 1:1 con Paciente
  alergias              String?                    @db.Text
  metodosIntervencion   String?                    @db.Text
  metodoLiquidosSolidos String?                    @db.Text
  posicionAdministracion String?                   @db.Text
  datosExtras           String?                    @db.Text
  tieneEpilepsia        Boolean                    @default(false)
  tipoCrisis            String?
  tieneOtrasCrisis      Boolean  @default(false)
  descripcionOtrasCrisis String? @db.Text
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt

  paciente              Paciente                   @relation(fields: [pacienteId], references: [userId], onDelete: Cascade)
  medicamentos          InformacionMedicamento[]
  archivosAdjuntos    ArchivoAdjunto[]

  @@index([pacienteId])
}


model ArchivoAdjunto {
  id                  String            @id @default(uuid()) @map("UniqueID")
  nombreArchivo       String            @map("nombre_archivo")
  uuid                String            @map("UUID")
  url                 String            @map("url")
  fechaCarga          DateTime          @default(now()) @map("fecha_carga")

  historialId         String               @map("historial_paciente")
  historial           HistorialPaciente @relation(fields: [historialId], references: [id], onDelete: Cascade)

  @@map("Archivos_adjuntos")
}


model CuidadoPersonal {
  id                String   @id @default(uuid())
  pacienteId        String   @unique  // 1:1 con Paciente
  tipoMovilidad     String?  // "Independiente", "Silla de ruedas", "Bastón", "Andador"
  cuidadoPersonal   String?  @db.Text
  maneraParaComer   String?  @db.Text
  maneraParaBeber   String?  @db.Text
  miSeguridad       String?  @db.Text
  usoBano           String?  @db.Text
  rutinaDescanso    String?  @db.Text
  problemasVistaAudicion  String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  paciente Paciente @relation(fields: [pacienteId], references: [userId], onDelete: Cascade)

  @@index([pacienteId])
}

// ─── Modelo de Perfil de Comunicación (1:1) ──────────────────────────────────
model PerfilComunicacion {
  id                      String   @id @default(uuid())
  pacienteId              String   @unique  // 1:1 con Paciente
  asistenteComunicacion   String?  // "Tablero de comunicación", "SAAC", "Lenguaje de señas"
  ayudaComunicacion       String?  @db.Text

  lenguajesQueHabla     String?  @db.Text
  necesitaAsistente     Boolean  @default(false)
  necesitaPersonaApoyo  Boolean  @default(false)

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  paciente Paciente @relation(fields: [pacienteId], references: [userId], onDelete: Cascade)

  @@index([pacienteId])
}

// ─── Modelo de Emociones (1:1) ────────────────────────────────────────────────
model EmocionesGustos {
  id                    String   @id @default(uuid())
  pacienteId            String   @unique  // 1:1 con Paciente
  descripcionAnsioso    String?  @db.Text
  descripcionDolor      String?  @db.Text
  descripcionAsustado   String?  @db.Text
  descripcionEnojado    String?  @db.Text

  loQueMeGusta          String?  @db.Text
  loQueNoMeGusta        String?  @db.Text

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  paciente Paciente @relation(fields: [pacienteId], references: [userId], onDelete: Cascade)

  @@index([pacienteId])
}
