<style>
  @media print {
    body { background-color: white !important; }
    .print-oculto { display: none !important; }
    .shadow-xl { box-shadow: none !important; border: 1px solid #e2e8f0; }
  }
</style>

<div class="min-h-screen bg-slate-50 flex items-center justify-center p-4">

  <div class="max-w-sm w-full bg-white rounded-3xl shadow-xl overflow-hidden border border-slate-200">

    <div class="bg-slate-800 p-6 text-center">
      <h1 class="text-2xl font-bitter text-white tracking-tight">Pasaporte Médico</h1>
      <p class="text-slate-300 text-sm mt-1">Escaneá para ver la informacion del paciente</p>
    </div>

    <div class="p-8 text-center flex flex-col items-center">

      <div class="bg-white p-2 rounded-2xl border-2 border-dashed border-slate-200 mb-6 inline-block">
        <img src="<%= locals.qrImage %>" alt="Código QR del Paciente" class="w-64 h-64 object-contain rounded-xl">
      </div>

      <h2 class="text-xl font-bold text-slate-800">
        <%= locals.usuarioPaciente?.user.nombre %> <%= locals.usuarioPaciente?.user.apellido %>
      </h2>
      <p class="text-sm font-medium text-slate-500 mt-2">Uso exclusivo interno de la ONG</p>

    </div>

    <div class="p-6 bg-slate-50 border-t border-slate-100 print-oculto">
        <a href="<%= locals.qrImage %>" download="QR_<%= locals.usuarioPaciente?.user.nombre %>_<%= locals.usuarioPaciente?.user.apellido %>.png"
            class="w-full mt-3 py-3.5 bg-white border-2 border-slate-200 hover:border-slate-300 hover:bg-slate-50 text-colorAzulFundacion font-bitter rounded-xl transition-all shadow-sm active:scale-95 flex items-center justify-center gap-2">
            Guardar QR como PNG
        </a>
      <div class="mt-4 text-center">
        <a href="/" class="text-sm font-medium text-slate-500 hover:text-slate-800 transition-colors">Volver al inicio</a>
      </div>
    </div>

  </div>

</div>
