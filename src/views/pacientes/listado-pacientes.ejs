<div class="min-h-screen bg-slate-50 px-4 pt-8 pb-12 md:pt-12">
  <div class="max-w-6xl mx-auto">

    <div class="mb-6">
        <a href="/" class="inline-flex items-center gap-2 text-sm font-medium text-slate-500 hover:text-slate-800 transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Volver al inicio
        </a>
    </div>

    <div class="mb-6">
      <h1 class="text-3xl text-azulFundacion font-bitter  text-slate-900 tracking-tight">Listado de pacientes</h1>
      <p class="text-sm text-slate-500 mt-1">Buscá y accedé rápidamente a las historias clínicas.</p>
    </div>

    <!-- Buscador -->
    <div class="mb-6">
      <form action="/pacientes" method="GET">
        <div class="relative w-full max-w-sm">
          <svg class="w-4 h-4 absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          <input type="text" name="search" value="<%= locals.searchQuery || '' %>"
            placeholder="Buscar por nombre, apellido o apodo..."
            class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-slate-200 bg-white text-sm text-slate-800 focus:ring-1 focus:ring-slate-400 focus:border-slate-400 outline-none transition-all shadow-sm">
          <button type="submit" class="hidden">Buscar</button>
        </div>
      </form>
    </div>

    <!-- Tabla -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-slate-50 border-b border-slate-200 text-xs uppercase tracking-wider text-slate-500 font-bold">
              <th class="text-colorAzulFundacion px-6 py-4">Nombre y apellido</th>
              <th class="text-colorAzulFundacion px-6 py-4">Apodo</th>
              <th class="text-colorAzulFundacion px-6 py-4">Fecha Nacimiento</th>
              <th class="text-colorAzulFundacion px-6 py-4 text-right">Acción</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">

            <% if (locals.pacientes && locals.pacientes.length > 0) { %>
              <% locals.pacientes.forEach(p => { %>
                <tr class="hover:bg-slate-50 transition-colors group">

                  <td class="px-6 py-4">
                    <div class="flex items-center gap-3">
                      <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-xs font-bold text-slate-600 shrink-0">
                        <%= p.user?.nombre?.[0]?.toUpperCase() || '?' %><%= p.user?.apellido?.[0]?.toUpperCase() || '' %>
                      </div>
                      <p class="font-semibold text-slate-800 text-sm"><%= p.user?.nombre %> <%= p.user?.apellido %></p>
                    </div>
                  </td>

                  <td class="px-6 py-4 text-sm text-slate-600">
                    <%= p.apodo || '—' %>
                  </td>

                  <td class="px-6 py-4 text-sm text-slate-600">
                    <% if (p.fechaNacimiento) { %>
                      <%= new Date(p.fechaNacimiento).toLocaleDateString('es-AR') %>
                    <% } else { %>
                      <span class="text-slate-400">—</span>
                    <% } %>
                  </td>

                  <td class="px-6 py-4 text-right">
                    <a href="/pacientes/<%= p.userId || p.id %>"
                       class="inline-flex items-center gap-1.5 px-3.5 py-1.5 bg-white border border-slate-200 text-slate-700 text-s font-bitter rounded-lg hover:border-slate-400 hover:bg-slate-50 transition-all">
                      Ver detalle
                      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                      </svg>
                    </a>
                  </td>

                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="4" class="px-6 py-16 text-center">
                  <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-slate-100 mb-4">
                    <svg class="w-7 h-7 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                  </div>
                  <p class="text-base font-semibold text-slate-700">No hay pacientes registrados</p>
                  <p class="text-sm text-slate-400 mt-1">Los pacientes aparecerán aquí una vez que sean dados de alta.</p>
                </td>
              </tr>
            <% } %>

          </tbody>
        </table>
      </div>

      <!-- Paginación -->
      <% if (locals.totalPaginas && locals.totalPaginas > 1) { %>
        <div class="px-6 py-4 border-t border-slate-100 flex items-center justify-between gap-4">

          <p class="text-xs text-slate-500">
            Mostrando <%= ((locals.paginaActual - 1) * locals.porPagina) + 1 %>–<%= Math.min(locals.paginaActual * locals.porPagina, locals.total) %> de <%= locals.total %> pacientes
          </p>

          <div class="flex items-center gap-1">
            <!-- Anterior -->
            <% if (locals.paginaActual > 1) { %>
              <a href="/pacientes?page=<%= locals.paginaActual - 1 %><%= locals.searchQuery ? '&search=' + locals.searchQuery : '' %>"
                class="px-3 py-1.5 text-xs font-medium text-slate-600 border border-slate-200 rounded-lg hover:bg-slate-50 transition-all">
                ← Anterior
              </a>
            <% } else { %>
              <span class="px-3 py-1.5 text-xs font-medium text-slate-300 border border-slate-100 rounded-lg cursor-not-allowed">← Anterior</span>
            <% } %>

            <!-- Números de página -->
            <% for (let i = 1; i <= locals.totalPaginas; i++) { %>
              <% if (
                i === 1 ||
                i === locals.totalPaginas ||
                (i >= locals.paginaActual - 1 && i <= locals.paginaActual + 1)
              ) { %>
                <a href="/pacientes?page=<%= i %><%= locals.searchQuery ? '&search=' + locals.searchQuery : '' %>"
                  class="px-3 py-1.5 text-xs font-medium rounded-lg transition-all <%= i === locals.paginaActual ? 'bg-slate-800 text-white border border-slate-800' : 'text-slate-600 border border-slate-200 hover:bg-slate-50' %>">
                  <%= i %>
                </a>
              <% } else if (
                i === locals.paginaActual - 2 ||
                i === locals.paginaActual + 2
              ) { %>
                <span class="px-2 py-1.5 text-xs text-slate-400">…</span>
              <% } %>
            <% } %>

            <!-- Siguiente -->
            <% if (locals.paginaActual < locals.totalPaginas) { %>
              <a href="/pacientes?page=<%= locals.paginaActual + 1 %><%= locals.searchQuery ? '&search=' + locals.searchQuery : '' %>"
                class="px-3 py-1.5 text-xs font-medium text-slate-600 border border-slate-200 rounded-lg hover:bg-slate-50 transition-all">
                Siguiente →
              </a>
            <% } else { %>
              <span class="px-3 py-1.5 text-xs font-medium text-slate-300 border border-slate-100 rounded-lg cursor-not-allowed">Siguiente →</span>
            <% } %>
          </div>

        </div>
      <% } %>

    </div>

  </div>
</div>
