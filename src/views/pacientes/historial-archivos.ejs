<div class="max-w-5xl mx-auto px-4 pb-12">
    <div class="flex flex-col sm:flex-row items-center w-full mb-6 mt-4 gap-4">
        <div class="flex w-full sm:flex-1 justify-start mb-2 sm:mb-0">
            <a href="/" class="inline-flex items-center gap-2 text-sm font-medium text-slate-500 hover:text-slate-800 transition-colors focus:outline-none focus:ring-2 focus:ring-indigo-500 rounded-lg p-1">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                Volver al inicio
            </a>
        </div>

        <h1 class="text-2xl font-bitter text-slate-800 tracking-tight shrink-0 text-center" tabindex="0">
            Historial de Archivos
        </h1>

        <div class="flex w-full sm:flex-1 justify-end">
            <% if (locals.user && (locals.user.rolNombre === 'PACIENTE')) { %>
                <a href="/pacientes/archivos" class="font-serif px-5 py-2.5 bg-colorAzulFundacion text-white text-sm font-medium rounded-lg hover:bg-slate-900 transition-all shadow-sm text-center focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2">
                Subir archivo
                </a>
            <% } %>
        </div>
    </div>

    <% if (locals.user?.rolNombre === 'ACOMPAÑANTE' && !locals.paciente) { %>
        <div class="bg-white rounded-2xl border-2 border-dashed border-slate-300 p-10 md:p-16 text-center shadow-sm mt-8">
          <div class="w-20 h-20 bg-indigo-50 rounded-full flex items-center justify-center mx-auto mb-5" aria-hidden="true">
            <svg class="w-10 h-10 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-slate-800 mb-3" tabindex="0">Sin acceso a documentos</h2>
          <p class="text-slate-600 text-base max-w-md mx-auto leading-relaxed" tabindex="0">
            No tenés un paciente asignado. Una vez que te vinculen a un pasaporte médico, vas a poder visualizar y descargar los estudios clínicos desde acá.
          </p>
        </div>
    <% } else { %>

        <% if (paciente && paciente.historial && paciente.historial.archivosAdjuntos && paciente.historial.archivosAdjuntos.length > 0) { %>
          <div class="bg-white border border-slate-200 rounded-2xl shadow-sm p-4 mb-4 flex flex-col sm:flex-row gap-4 items-center justify-between">
            <div class="relative w-full sm:w-96">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="h-5 w-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
              </div>
              <input type="text" id="inputBuscador" placeholder="Buscar por nombre..." aria-label="Buscar archivo por nombre" class="block w-full pl-10 pr-3 py-2.5 border border-slate-200 rounded-xl leading-5 bg-slate-50 placeholder-slate-400 focus:outline-none focus:bg-white focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm transition-colors">
            </div>

            <div class="flex items-center gap-3 w-full sm:w-auto">
              <label for="selectFiltro" class="text-sm font-medium text-slate-700">Ordenar por fecha de carga:</label>
              <select id="selectFiltro" class="block w-full sm:w-auto pl-3 pr-10 py-2.5 text-sm font-medium border border-slate-200 rounded-xl bg-slate-50 text-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors cursor-pointer">
                <option value="desc">Más recientes</option>
                <option value="asc">Más antiguos</option>
              </select>
            </div>
          </div>
        <% } %>

        <div class="bg-white border border-slate-200 rounded-2xl shadow-sm min-h-[400px] relative">
          <div class="w-full overflow-x-auto rounded-2xl">
            <table class="w-full text-left border-collapse whitespace-nowrap">
              <thead>
                <tr class="border-b border-slate-200 text-xs font-bold text-slate-500 uppercase tracking-wider">
                  <th class="text-colorAzulFundacion px-6 py-5 font-sans">Nombre Archivo</th>
                  <th class="text-colorAzulFundacion px-6 py-5 font-sans">Tipo</th>
                  <th class="text-colorAzulFundacion px-6 py-5 font-sans">Fecha de carga</th>
                  <th class="text-colorAzulFundacion px-6 py-5 font-sans text-right">Acción</th>
                </tr>
              </thead>
              <tbody id="tablaArchivosBody" class="divide-y divide-slate-100">
                <% if (paciente && paciente.historial && paciente.historial.archivosAdjuntos && paciente.historial.archivosAdjuntos.length > 0) { %>
                  <% paciente.historial.archivosAdjuntos.forEach(archivo => { %>
                    <tr class="hover:bg-slate-50/70 transition-colors fila-archivo focus:outline-none focus:bg-slate-50 focus:ring-inset focus:ring-2 focus:ring-indigo-500/50"
                        tabindex="0"
                        aria-label="Archivo: <%= archivo.nombreArchivo %>, cargado el <%= new Date(archivo.fechaCarga).toLocaleDateString('es-AR') %>"
                        data-nombre="<%= archivo.nombreArchivo.toLowerCase() %>"
                        data-fecha="<%= new Date(archivo.fechaCarga).getTime() %>">

                      <td class="px-6 py-4">
                        <div class="flex items-center gap-4">
                          <div class="w-10 h-10 rounded-full bg-slate-100 text-slate-600 flex items-center justify-center text-xs font-bold uppercase shrink-0" aria-hidden="true">
                            <%= archivo.url.split('.').pop() %>
                          </div>
                          <span class="text-sm font-bold text-slate-800 truncate max-w-[200px] md:max-w-xs"><%= archivo.nombreArchivo %></span>
                        </div>
                      </td>
                      <td class="px-6 py-4">
                        <span class="text-sm font-medium text-slate-500"><%= archivo.url.split('.').pop().toLowerCase() === 'pdf' ? 'Documento PDF' : 'Imagen' %></span>
                      </td>
                      <td class="px-6 py-4">
                        <span class="text-sm font-medium text-slate-500"><%= new Date(archivo.fechaCarga).toLocaleDateString('es-AR') %></span>
                      </td>
                      <td class="px-6 py-4 text-right">
                        <div class="inline-block text-left dropdown-container">
                          <button type="button" aria-label="Opciones" class="dropdown-btn inline-flex items-center justify-center border border-slate-200 rounded-lg px-4 py-2 text-sm font-bitter text-slate-600 hover:bg-slate-50 shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
                            Opciones
                          </button>
                          <div class="dropdown-menu hidden fixed z-[150] w-48 rounded-xl bg-white shadow-lg ring-1 ring-black ring-opacity-5">
                            <a href="<%= archivo.url %>" target="_blank" class="block px-4 py-3 text-sm font-bitter text-slate-700 hover:bg-slate-50 border-b border-slate-50">Visualizar</a>
                            <a href="<%= archivo.url.replace('/upload/', '/upload/fl_attachment/') %>" class="block px-4 py-3 text-sm font-bitter text-slate-700 hover:bg-slate-50 border-b border-slate-50">Descargar</a>
                            <% if (locals.user && (locals.user.rolNombre === 'PACIENTE')) { %>
                                <button type="button" data-id="<%= archivo.id %>" class="btn-abrir-modal-eliminar w-full text-left block px-4 py-3 text-sm font-bitter text-red-600 hover:bg-red-50">Eliminar</button>
                            <% } %>
                          </div>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                  <tr id="filaSinResultados" class="hidden">
                    <td colspan="4" class="px-6 py-16 text-center">No se encontraron archivos.</td>
                  </tr>
                <% } else { %>
                  <tr>
                    <td colspan="4" class="px-6 py-24 text-center">
                      <p class="text-slate-500">Aún no hay documentos adjuntos.</p>
                    </td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
    <% } %>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {

    const inputBuscador = document.getElementById('inputBuscador');
    const selectOrden = document.getElementById('selectFiltro'); // Actualizado para que coincida con el ID del HTML
    const tablaBody = document.getElementById('tablaArchivosBody');
    const filaSinResultados = document.getElementById('filaSinResultados');

    // 1. Buscador y Filtro de ordenamiento
    if (inputBuscador && selectOrden && tablaBody) {
      const filasOriginales = Array.from(tablaBody.querySelectorAll('.fila-archivo'));

      const aplicarFiltros = () => {
        const busqueda = inputBuscador.value.toLowerCase().trim();
        const orden = selectOrden.value;
        let filasVisibles = 0;


        const filasFiltradas = filasOriginales.filter(fila => {
          const nombreArchivo = fila.getAttribute('data-nombre');
          if (nombreArchivo.includes(busqueda)) {
            fila.style.display = '';
            filasVisibles++;
            return true;
          } else {
            fila.style.display = 'none';
            return false;
          }
        });

        filasFiltradas.sort((a, b) => {
          const fechaA = parseInt(a.getAttribute('data-fecha'));
          const fechaB = parseInt(b.getAttribute('data-fecha'));

          if (orden === 'desc') {
            return fechaB - fechaA;
          } else {
            return fechaA - fechaB;
          }
        });

        filasFiltradas.forEach(fila => tablaBody.appendChild(fila));

        if (filaSinResultados) {
          tablaBody.appendChild(filaSinResultados);
          if (filasVisibles === 0 && busqueda !== '') {
            filaSinResultados.classList.remove('hidden');
          } else {
            filaSinResultados.classList.add('hidden');
          }
        }
      };

      inputBuscador.addEventListener('input', aplicarFiltros);
      selectOrden.addEventListener('change', aplicarFiltros);

      aplicarFiltros();
    }

    // 2. Menú Desplegable (Dropdowns de Opciones)
    const dropdownBtns = document.querySelectorAll('.dropdown-btn');
    dropdownBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();

        const menu = btn.nextElementSibling;
        const isHidden = menu.classList.contains('hidden');

        // Cierra todos los demás menús
        document.querySelectorAll('.dropdown-menu').forEach(m => {
          m.classList.add('hidden');
          m.previousElementSibling.setAttribute('aria-expanded', 'false');
        });

        // Abre el menú seleccionado calculando su posición en pantalla
        if (isHidden) {
          menu.classList.remove('hidden');
          btn.setAttribute('aria-expanded', 'true');
          const rect = btn.getBoundingClientRect();
          menu.style.top = `${rect.bottom + 4}px`;
          menu.style.left = `${rect.right - menu.offsetWidth}px`;
        }
      });
    });

    // Cierra los menús al hacer clic afuera
    document.addEventListener('click', () => {
      document.querySelectorAll('.dropdown-menu').forEach(menu => {
        menu.classList.add('hidden');
        menu.previousElementSibling.setAttribute('aria-expanded', 'false');
      });
    });

    // Cierra los menús al hacer scroll (para que no queden flotando raros)
    window.addEventListener('scroll', () => {
      document.querySelectorAll('.dropdown-menu').forEach(menu => {
        menu.classList.add('hidden');
        menu.previousElementSibling.setAttribute('aria-expanded', 'false');
      });
    }, true);

    // 3. Modal de Eliminación
    const modalEliminar = document.getElementById('modalEliminar');
    const formEliminar = document.getElementById('formEliminar');
    const btnCancelarModal = document.getElementById('btnCancelarModal');
    const backdropModal = document.getElementById('backdropModal');
    const botonesEliminar = document.querySelectorAll('.btn-abrir-modal-eliminar');

    botonesEliminar.forEach(boton => {
      boton.addEventListener('click', (e) => {
        const archivoId = boton.getAttribute('data-id');
        // Asignar la ruta de eliminación dinámica al formulario
        formEliminar.action = `/pacientes/archivos/${archivoId}/eliminar`;
        modalEliminar.classList.remove('hidden');

        // Cierra el menú desplegable del archivo para que no quede encima del modal
        const menuPadre = boton.closest('.dropdown-menu');
        if(menuPadre) {
          menuPadre.classList.add('hidden');
          menuPadre.previousElementSibling.setAttribute('aria-expanded', 'false');
        }
      });
    });

    const cerrarModal = () => {
      modalEliminar.classList.add('hidden');
      formEliminar.action = '';
    };

    if (btnCancelarModal) btnCancelarModal.addEventListener('click', cerrarModal);
    if (backdropModal) backdropModal.addEventListener('click', cerrarModal);
  });
</script>
