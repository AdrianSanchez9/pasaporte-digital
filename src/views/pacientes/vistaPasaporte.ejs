<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=DM+Mono:wght@500&display=swap');

  .passport-root {
    font-family: 'DM Sans', sans-serif;
    background: #f1f5f9;
    min-height: 100vh;
    padding: 2rem 1rem;
  }

  .passport-wrap {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .cred-card {
    background: #fff;
    border: 0.5px solid #cbd5e1;
    border-radius: 20px;
    overflow: hidden;
  }

  .cred-top {
    display: flex;
    min-height: 160px;
  }

  .cred-panel {
    width: 200px;
    flex-shrink: 0;
    background: #1e293b;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1.5rem 1.25rem;
    gap: 10px;
  }

  .cred-avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid #334155;
    background: #334155;
    flex-shrink: 0;
  }

  .cred-name-block { text-align: center; }

  .cred-fullname {
    color: #f8fafc;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.3;
    word-break: break-word;
  }

  .cred-apodo {
    color: #94a3b8;
    font-size: 12px;
    font-weight: 400;
    margin-top: 3px;
  }

  .cred-right {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .cred-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    padding: 1rem 1.25rem 0.75rem;
    border-bottom: 0.5px solid #e2e8f0;
  }

  .meta-pill {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 12px;
    color: #475569;
    background: #f8fafc;
    border: 0.5px solid #cbd5e1;
    border-radius: 99px;
    padding: 4px 10px;
    font-weight: 500;
  }

  .meta-pill-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #94a3b8;
    font-weight: 600;
  }

  .cred-alerts {
    padding: 0.875rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
    justify-content: center;
  }

  .alerts-title {
    font-size: 9px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #dc2626;
    margin-bottom: 4px;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .alerts-title svg { width: 12px; height: 12px; }

  .alert-row {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #fef2f2;
    border: 0.5px solid #fca5a5;
    border-radius: 10px;
    padding: 7px 10px;
  }

  .alert-icon-wrap {
    width: 28px;
    height: 28px;
    border-radius: 8px;
    background: #dc2626;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .alert-icon-wrap svg {
    width: 14px; height: 14px;
    color: #fff; stroke: #fff; fill: none;
    stroke-width: 2; stroke-linecap: round; stroke-linejoin: round;
  }

  .alert-text-title { font-size: 12px; font-weight: 600; color: #991b1b; line-height: 1.2; }
  .alert-text-desc  { font-size: 11px; color: #7f1d1d; line-height: 1.4; margin-top: 1px; }

  /* ── SECCIONES GENERALES ── */
  .section-card {
    background: #fff;
    border: 0.5px solid #cbd5e1;
    border-radius: 20px;
    overflow: hidden;
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0.875rem 1.25rem;
    border-bottom: 0.5px solid #e2e8f0;
  }

  .section-header-icon {
    width: 28px; height: 28px;
    border-radius: 8px;
    background: #f1f5f9;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }

  .section-header-icon svg {
    width: 15px; height: 15px;
    stroke: #64748b; fill: none;
    stroke-width: 2; stroke-linecap: round; stroke-linejoin: round;
  }

  .section-title {
    font-size: 13px;
    font-weight: 600;
    color: #1e293b;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .section-body { padding: 1rem 1.25rem; }

  /* ── GRID DE CAMPOS ── */
  .fields-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 8px;
  }

  .field-item {
    background: #f8fafc;
    border: 0.5px solid #e2e8f0;
    border-radius: 10px;
    padding: 0.6rem 0.875rem;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .field-img {
    width: 40px; height: 40px;
    object-fit: contain; flex-shrink: 0; border-radius: 6px;
  }

  .field-label {
    font-size: 9px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: #94a3b8;
    margin-bottom: 2px;
  }

  .field-value {
    font-size: 13px;
    font-weight: 500;
    color: #334155;
    word-break: break-word;
  }

  .field-item.span2 { grid-column: span 2; }
  @media (max-width: 600px) { .field-item.span2 { grid-column: span 1; } }

  /* ── DOS COLUMNAS ── */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  @media (max-width: 640px) {
    .two-col { grid-template-columns: 1fr; }
    .cred-top { flex-direction: column; }
    .cred-panel { width: 100%; flex-direction: row; padding: 1rem; justify-content: flex-start; }
    .cred-name-block { text-align: left; }
  }

  /* ── CONTACTOS ── */
  .contact-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    background: #f8fafc;
    border: 0.5px solid #e2e8f0;
    border-radius: 12px;
    padding: 0.75rem 1rem;
    margin-bottom: 8px;
  }
  .contact-row:last-child { margin-bottom: 0; }

  .contact-avatar {
    width: 36px; height: 36px;
    border-radius: 50%;
    background: #e2e8f0;
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 600; color: #475569;
    flex-shrink: 0;
  }

  .contact-name  { font-size: 13px; font-weight: 600; color: #1e293b; }
  .contact-rel   { font-size: 11px; color: #64748b; margin-top: 1px; }
  .contact-tel   { font-size: 13px; font-weight: 600; color: #475569; font-family: 'DM Mono', monospace; white-space: nowrap; }

  /* ── MEDICACIÓN ── */
  .meds-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 10px; }

  .med-card {
    background: #f8fafc;
    border: 0.5px solid #e2e8f0;
    border-radius: 12px;
    padding: 0.875rem 1rem;
  }

  .med-name {
    font-size: 13px; font-weight: 600; color: #1e293b;
    padding-bottom: 0.6rem;
    border-bottom: 0.5px solid #e2e8f0;
    margin-bottom: 0.75rem;
    word-break: break-word;
    display: flex; align-items: center; gap: 6px;
  }

  .med-name svg {
    width: 14px; height: 14px; stroke: #6366f1; fill: none;
    stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; flex-shrink: 0;
  }

  .med-details { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
  .med-detail-label { font-size: 9px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.07em; color: #94a3b8; margin-bottom: 2px; }
  .med-detail-value { font-size: 12px; font-weight: 600; color: #334155; word-break: break-word; }

  .med-time {
    display: inline-flex; align-items: center; gap: 4px;
    background: #eef2ff; color: #4338ca;
    border-radius: 99px; padding: 3px 9px;
    font-size: 11px; font-weight: 600; font-family: 'DM Mono', monospace;
  }
  .med-time svg { width: 11px; height: 11px; stroke: #4338ca; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }

  .info-block {
    display: flex;
    gap: 10px;
    margin-bottom: 10px;
    align-items: flex-start;
  }
  .info-block:last-child { margin-bottom: 0; }

  .info-block-icon {
    width: 28px;
    height: 28px;
    border-radius: 7px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .info-block-icon svg {
    width: 14px; height: 14px;
    fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round;
  }

  .info-block-content {
    flex: 1;
    min-width: 0;
    border-left: 2px solid #e2e8f0;
    padding-left: 10px;
  }

  .info-block-label {
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #94a3b8;
    margin-bottom: 3px;
  }

  .info-block-value {
    font-size: 13px;
    font-weight: 400;
    color: #334155;
    line-height: 1.55;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .info-block.blue  .info-block-icon { background: #eff6ff; }
  .info-block.blue  .info-block-icon svg { stroke: #3b82f6; }
  .info-block.blue  .info-block-content { border-left-color: #bfdbfe; }

  .info-block.green .info-block-icon { background: #f0fdf4; }
  .info-block.green .info-block-icon svg { stroke: #22c55e; }
  .info-block.green .info-block-content { border-left-color: #bbf7d0; }

  .info-block.amber .info-block-icon { background: #fffbeb; }
  .info-block.amber .info-block-icon svg { stroke: #f59e0b; }
  .info-block.amber .info-block-content { border-left-color: #fde68a; }

  .info-block.slate .info-block-icon { background: #f8fafc; }
  .info-block.slate .info-block-icon svg { stroke: #64748b; }
  .info-block.slate .info-block-content { border-left-color: #cbd5e1; }

  .info-block.indigo .info-block-icon { background: #eef2ff; }
  .info-block.indigo .info-block-icon svg { stroke: #6366f1; }
  .info-block.indigo .info-block-content { border-left-color: #c7d2fe; }

  .comm-tag {
    display: inline-flex; align-items: center; gap: 5px;
    background: #eef2ff; color: #4338ca;
    border-radius: 8px; padding: 5px 10px;
    font-size: 12px; font-weight: 600;
    margin: 3px 3px 3px 0;
  }
  .comm-tag svg { width: 13px; height: 13px; stroke: #4338ca; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }

  .emotions-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }

  .emotion-item {
    border-radius: 12px;
    padding: 0.75rem 0.875rem;
    border: 0.5px solid transparent;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .emotion-item.ansioso  { background: #fffbeb; border-color: #fde68a; }
  .emotion-item.dolor    { background: #fff7ed; border-color: #fed7aa; }
  .emotion-item.miedo    { background: #eff6ff; border-color: #bfdbfe; }
  .emotion-item.enojo    { background: #fef2f2; border-color: #fecaca; }
  .emotion-item.gusta    { background: #f0fdf4; border-color: #bbf7d0; }
  .emotion-item.nogusta  { background: #fdf4ff; border-color: #e9d5ff; }

  .emotion-full { grid-column: span 2; }

  .emotion-emoji { font-size: 20px; display: block; }

  .emotion-label {
    font-size: 9px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.08em;
  }
  .emotion-item.ansioso .emotion-label  { color: #92400e; }
  .emotion-item.dolor   .emotion-label  { color: #9a3412; }
  .emotion-item.miedo   .emotion-label  { color: #1e40af; }
  .emotion-item.enojo   .emotion-label  { color: #991b1b; }
  .emotion-item.gusta   .emotion-label  { color: #166534; }
  .emotion-item.nogusta .emotion-label  { color: #6b21a8; }

  .emotion-desc {
    font-size: 12px; font-weight: 500; color: #334155;
    line-height: 1.45; white-space: pre-wrap; word-break: break-word;
  }

  /* ── WARNING visión/audición ── */
  .warning-block {
    background: #fefce8; border: 0.5px solid #fde047;
    border-radius: 10px; padding: 0.65rem 0.875rem; margin-top: 8px;
  }
  .warning-label { font-size: 9px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.07em; color: #a16207; margin-bottom: 2px; }
  .warning-value { font-size: 12px; font-weight: 500; color: #713f12; white-space: pre-wrap; word-break: break-word; }

  /* ── ARCHIVOS ── */
  .file-row {
    display: flex; align-items: center; justify-content: space-between; gap: 12px;
    background: #f8fafc; border: 0.5px solid #e2e8f0; border-radius: 10px;
    padding: 0.65rem 0.875rem; margin-bottom: 8px; transition: border-color 0.15s;
  }
  .file-row:last-child { margin-bottom: 0; }
  .file-row:hover { border-color: #cbd5e1; }

  .file-ext {
    width: 32px; height: 32px; border-radius: 6px; background: #e2e8f0;
    display: flex; align-items: center; justify-content: center;
    font-size: 9px; font-weight: 700; color: #475569; text-transform: uppercase; flex-shrink: 0;
  }
  .file-name { font-size: 12px; font-weight: 600; color: #334155; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .file-date { font-size: 10px; color: #94a3b8; margin-top: 1px; }

  .file-link {
    color: #94a3b8; padding: 6px; border-radius: 8px;
    display: flex; align-items: center; text-decoration: none;
    transition: background 0.15s, color 0.15s; flex-shrink: 0;
  }
  .file-link:hover { background: #e2e8f0; color: #475569; }
  .file-link svg { width: 16px; height: 16px; stroke: currentColor; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }

  /* ── BOTÓN ── */
  .btn-primary {
    display: block; width: 100%; text-align: center;
    padding: 0.75rem 1rem; background: #1e293b; color: #fff;
    font-size: 13px; font-weight: 600; border-radius: 12px;
    text-decoration: none; transition: background 0.15s; margin-top: 1rem;
  }
  .btn-primary:hover { background: #0f172a; }

  /* ── FIELD GROUP ── */
  .field-group { margin-bottom: 10px; }
  .field-group:last-child { margin-bottom: 0; }

  /* ── EMPTY ── */
  .empty-msg {
    font-size: 12px; color: #94a3b8; background: #f8fafc;
    border: 0.5px solid #e2e8f0; border-radius: 10px; padding: 1rem; text-align: center;
  }

  @media print {
    body { background: white !important; }
    .print-oculto { display: none !important; }
  }
</style>

<div class="passport-root">
  <div class="passport-wrap">

    <%
      const tieneEpilepsia = locals.historial?.tieneEpilepsia;
      const tieneOtrasCrisis = locals.historial?.tieneOtrasCrisis;
      const tieneAlergias = locals.historial?.alergias && locals.historial.alergias.trim() !== '';
      const hayAlertas = tieneEpilepsia || tieneOtrasCrisis || tieneAlergias;
    %>

    <!-- ══ CARD PRINCIPAL: credencial horizontal ══ -->
    <div class="cred-card">
      <div class="cred-top">

        <div class="cred-panel">
          <img
            src="<%= locals.paciente?.fotoPerfil ? locals.paciente.fotoPerfil.replace('/upload/', '/upload/c_fill,g_face,w_256,h_256,q_auto,f_auto/') : '/img/default-avatar.svg' %>"
            alt="Foto de perfil"
            class="cred-avatar"
          >
          <div class="cred-name-block">
            <p class="cred-fullname"><%= locals.usuarioPaciente?.nombre %> <%= locals.usuarioPaciente?.apellido %></p>
            <% if (locals.paciente?.apodo) { %>
              <p class="cred-apodo">"<%= locals.paciente.apodo %>"</p>
            <% } %>
          </div>
        </div>

        <div class="cred-right">
          <div class="cred-meta">
            <% if (locals.paciente?.fechaNacimiento) { %>
              <span class="meta-pill">
                <span class="meta-pill-label">Nac.</span>
                <%= new Date(locals.paciente.fechaNacimiento).toLocaleDateString('es-AR') %>
              </span>
            <% } %>
            <% if (locals.paciente?.dni) { %>
              <span class="meta-pill">
                <span class="meta-pill-label">DNI</span>
                <%= locals.paciente.dni %>
              </span>
            <% } %>
            <% if (locals.paciente?.nroObraSocial) { %>
              <span class="meta-pill">
                <span class="meta-pill-label">O. Social</span>
                <%= locals.paciente.nroObraSocial %>
              </span>
            <% } %>
            <% if (locals.paciente?.nacionalidad) { %>
              <span class="meta-pill">
                <span class="meta-pill-label">Nacionalidad</span>
                <%= locals.paciente.nacionalidad %>
              </span>
            <% } %>
          </div>

          <% if (hayAlertas) { %>
            <div class="cred-alerts">
              <p class="alerts-title">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                Alertas médicas críticas
              </p>
              <% if (tieneEpilepsia) { %>
                <div class="alert-row">
                  <div class="alert-icon-wrap">
                    <svg viewBox="0 0 24 24"><path d="M9.5 2a2.5 2.5 0 015 0v2.5h3a2 2 0 012 2v1a2 2 0 01-2 2h-1v1.5a5 5 0 01-10 0V9.5H5a2 2 0 01-2-2v-1a2 2 0 012-2h3V2z"/><path d="M12 14v4m-3-2h6"/></svg>
                  </div>
                  <div>
                    <p class="alert-text-title">Paciente con Epilepsia</p>
                    <p class="alert-text-desc">Crisis: <%= locals.historial?.tipoCrisis || 'No especificado' %></p>
                  </div>
                </div>
              <% } %>
              <% if (tieneOtrasCrisis) { %>
                <div class="alert-row">
                  <div class="alert-icon-wrap">
                    <svg viewBox="0 0 24 24"><polyline points="13 2 13 9 20 9"/><path d="M20 9L13 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V9z"/><line x1="9" y1="14" x2="15" y2="14"/><line x1="9" y1="18" x2="15" y2="18"/></svg>
                  </div>
                  <div>
                    <p class="alert-text-title">Alerta de Crisis (Otro tipo)</p>
                    <p class="alert-text-desc"><%= locals.historial?.descripcionOtrasCrisis || 'No especificada' %></p>
                  </div>
                </div>
              <% } %>
              <% if (tieneAlergias) { %>
                <div class="alert-row">
                  <div class="alert-icon-wrap">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
                  </div>
                  <div>
                    <p class="alert-text-title">Alergias Reportadas</p>
                    <p class="alert-text-desc"><%= locals.historial.alergias %></p>
                  </div>
                </div>
              <% } %>
            </div>
          <% } else { %>
            <div class="cred-alerts">
              <p style="font-size:12px;color:#94a3b8;">Sin alertas médicas registradas.</p>
            </div>
          <% } %>
        </div>
      </div>
    </div>


    <!-- ══ DATOS PERSONALES ══ -->
    <div class="section-card">
      <div class="section-header">
        <div class="section-header-icon">
          <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
        <span class="section-title">Datos Personales</span>
      </div>
      <div class="section-body">
        <div class="fields-grid">
          <% if (locals.paciente?.telefono) { %>
            <div class="field-item">
              <img src="/img/telefono.png" alt="" class="field-img" onerror="this.style.display='none'">
              <div>
                <p class="field-label">Teléfono</p>
                <p class="field-value"><%= locals.paciente.telefono %></p>
              </div>
            </div>
          <% } %>
          <% if (locals.paciente?.direccion) { %>
            <div class="field-item span2">
              <img src="/img/direccion.png" alt="" class="field-img" onerror="this.style.display='none'">
              <div>
                <p class="field-label">Dirección</p>
                <p class="field-value"><%= locals.paciente.direccion %></p>
              </div>
            </div>
          <% } %>
          <% if (locals.paciente?.religion) { %>
            <div class="field-item">
              <img src="/img/religion.jpg" alt="" class="field-img" onerror="this.style.display='none'">
              <div>
                <p class="field-label">Religión</p>
                <p class="field-value"><%= locals.paciente.religion %></p>
              </div>
            </div>
          <% } %>
          <% if (locals.paciente?.necesidadesReligiosas) { %>
            <div class="field-item span2">
              <img src="/img/religion.jpg" alt="" class="field-img" onerror="this.style.display='none'">
              <div>
                <p class="field-label">Necesidades religiosas</p>
                <p class="field-value"><%= locals.paciente.necesidadesReligiosas %></p>
              </div>
            </div>
          <% } %>
        </div>
      </div>
    </div>


    <!-- ══ CONTACTOS + MÉDICO CABECERA ══ -->
    <div class="two-col">

      <div class="section-card">
        <div class="section-header">
          <div class="section-header-icon">
            <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2A19.79 19.79 0 013.07 4.18 2 2 0 015.07 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L9.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
          </div>
          <span class="section-title">Contactos de Emergencia</span>
        </div>
        <div class="section-body">
          <% if (locals.paciente?.contactos?.length > 0) { %>
            <% locals.paciente.contactos.forEach(c => { %>
              <div class="contact-row">
                <div class="contact-avatar"><%= (c.nombre || '?')[0].toUpperCase() %></div>
                <div style="flex:1;min-width:0;">
                  <p class="contact-name"><%= c.nombre %></p>
                  <p class="contact-rel"><%= c.relacion || 'Familiar' %></p>
                </div>
                <p class="contact-tel"><%= c.telefono %></p>
              </div>
            <% }) %>
          <% } else { %>
            <p class="empty-msg">No hay contactos registrados.</p>
          <% } %>
        </div>
      </div>

      <div class="section-card">
        <div class="section-header">
          <div class="section-header-icon">
            <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <span class="section-title">Médico Cabecera</span>
        </div>
        <div class="section-body">
          <% if (locals.paciente?.medicoCabecera) { %>
            <div class="contact-row" style="align-items:flex-start;">
              <div class="contact-avatar" style="background:#dcfce7;color:#166534;">
                <%= (locals.paciente.medicoCabecera.nombre || 'M')[0].toUpperCase() %>
              </div>
              <div style="flex:1;min-width:0;">
                <p class="contact-name"><%= locals.paciente.medicoCabecera.nombre %> <%= locals.paciente.medicoCabecera.apellido %></p>
                <p class="contact-rel">Médico Cabecera</p>
                <% if (locals.paciente.medicoCabecera.direccion) { %>
                  <p class="field-label" style="margin-top:8px;">Consultorio</p>
                  <p style="font-size:12px;font-weight:500;color:#334155;margin-top:2px;"><%= locals.paciente.medicoCabecera.direccion %></p>
                <% } %>
              </div>
              <% if (locals.paciente.medicoCabecera.telefono) { %>
                <p class="contact-tel"><%= locals.paciente.medicoCabecera.telefono %></p>
              <% } %>
            </div>
          <% } else { %>
            <p class="empty-msg">No hay médico registrado.</p>
          <% } %>
        </div>
      </div>

    </div>


    <!-- ══ MEDICACIÓN ACTUAL ══ -->
    <div class="section-card">
      <div class="section-header">
        <div class="section-header-icon">
          <svg viewBox="0 0 24 24"><path d="M10.5 20H4a2 2 0 01-2-2V6a2 2 0 012-2h16a2 2 0 012 2v7"/><path d="M18 21a3 3 0 100-6 3 3 0 000 6z"/><path d="M15.5 18.5L18 21l4-4"/></svg>
        </div>
        <span class="section-title">Medicación Actual</span>
      </div>
      <div class="section-body">
        <% if (locals.historial?.medicamentos?.length > 0) { %>
          <div class="meds-grid">
            <% locals.historial.medicamentos.forEach(med => { %>
              <div class="med-card">
                <p class="med-name">
                  <svg viewBox="0 0 24 24"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0016.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 002 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
                  <%= med.medicamento?.nombre || med.medicamentoPersonalizado || 'Sin nombre' %>
                </p>
                <div class="med-details">
                  <div>
                    <p class="med-detail-label">Dosis</p>
                    <p class="med-detail-value"><%= med.dosis || '—' %></p>
                  </div>
                  <div>
                    <p class="med-detail-label">Forma</p>
                    <p class="med-detail-value"><%= med.formaMedicamento || '—' %></p>
                  </div>
                  <div>
                    <p class="med-detail-label">Horarios</p>
                    <span class="med-time">
                      <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                      <%= med.horarios || '—' %>
                    </span>
                  </div>
                  <div>
                    <p class="med-detail-label">Ingesta</p>
                    <p class="med-detail-value"><%= med.momentoIngesta || '—' %></p>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <p class="empty-msg">No requiere medicación registrada.</p>
        <% } %>
      </div>
    </div>


    <!-- ══ HISTORIAL CLÍNICO + CUIDADO Y MOVILIDAD ══ -->
    <div class="two-col">

      <div class="section-card">
        <div class="section-header">
          <div class="section-header-icon">
            <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          </div>
          <span class="section-title">Historial Clínico Extra</span>
        </div>
        <div class="section-body">

          <% if (locals.historial?.metodosIntervencion) { %>
            <div class="info-block blue">
              <div class="info-block-icon">
                <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div class="info-block-content">
                <p class="info-block-label">Intervenciones Previas</p>
                <p class="info-block-value"><%= locals.historial.metodosIntervencion %></p>
              </div>
            </div>
          <% } %>

          <% if (locals.historial?.metodoLiquidosSolidos) { %>
            <div class="info-block green">
              <div class="info-block-icon">
                <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/><path d="M8 12h8M12 8v8"/></svg>
              </div>
              <div class="info-block-content">
                <p class="info-block-label">Ingesta de Líquidos/Sólidos</p>
                <p class="info-block-value"><%= locals.historial.metodoLiquidosSolidos %></p>
              </div>
            </div>
          <% } %>

          <% if (locals.historial?.maneraAdministrarMedicacion) { %>
            <div class="info-block indigo">
              <div class="info-block-icon">
                <svg viewBox="0 0 24 24"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0016.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 002 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
              </div>
              <div class="info-block-content">
                <p class="info-block-label">Manera de dar la medicación</p>
                <p class="info-block-value"><%= locals.historial.maneraAdministrarMedicacion %></p>
              </div>
            </div>
          <% } %>

          <% if (locals.historial?.datosExtras) { %>
            <div class="info-block slate">
              <div class="info-block-icon">
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              </div>
              <div class="info-block-content">
                <p class="info-block-label">Datos Extras Relevantes</p>
                <p class="info-block-value"><%= locals.historial.datosExtras %></p>
              </div>
            </div>
          <% } %>

          <% if (!locals.historial?.metodosIntervencion && !locals.historial?.metodoLiquidosSolidos && !locals.historial?.maneraAdministrarMedicacion && !locals.historial?.datosExtras) { %>
            <p class="empty-msg">No hay información extra cargada.</p>
          <% } %>

        </div>
      </div>

      <div class="section-card">
        <div class="section-header">
          <div class="section-header-icon">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="5" r="1"/><path d="M9 20l3-3 3 3"/><path d="M6.5 15.5a5 5 0 0111 0"/><path d="M12 17V7"/></svg>
          </div>
          <span class="section-title">Cuidado y Movilidad</span>
        </div>
        <div class="section-body">

          <% if (locals.cuidadoPersonal?.tipoMovilidad) { %>
            <div class="field-group">
              <p class="field-label">Tipo de Movilidad</p>
              <span class="comm-tag" style="margin:0;">
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l2 2"/></svg>
                <%= locals.cuidadoPersonal.tipoMovilidad %>
              </span>
            </div>
          <% } %>

          <% if (locals.cuidadoPersonal?.cuidadoPersonal || locals.cuidadoPersonal?.usoBano) { %>
            <div class="info-block blue">
              <div class="info-block-icon">
                <svg viewBox="0 0 24 24"><path d="M20 7H4a2 2 0 00-2 2v10a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z"/><path d="M16 3h-8v4h8V3z"/></svg>
              </div>
              <div class="info-block-content">
                <p class="info-block-label">Asistencia en Higiene</p>
                <p class="info-block-value"><%= [locals.cuidadoPersonal?.cuidadoPersonal, locals.cuidadoPersonal?.usoBano].filter(Boolean).map(s => s.trim()).join(' | ') %></p>
              </div>
            </div>
          <% } %>

          <% if (locals.cuidadoPersonal?.rutinaDescanso) { %>
            <div class="info-block green">
              <div class="info-block-icon">
                <svg viewBox="0 0 24 24"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
              </div>
              <div class="info-block-content">
                <p class="info-block-label">Rutina de Descanso</p>
                <p class="info-block-value"><%= locals.cuidadoPersonal.rutinaDescanso %></p>
              </div>
            </div>
          <% } %>

          <% if (locals.cuidadoPersonal?.seguridad) { %>
            <div class="info-block amber">
              <div class="info-block-icon">
                <svg viewBox="0 0 24 24"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              </div>
              <div class="info-block-content">
                <p class="info-block-label">Pautas de Seguridad</p>
                <p class="info-block-value"><%= locals.cuidadoPersonal.seguridad %></p>
              </div>
            </div>
          <% } %>

          <% if (locals.cuidadoPersonal?.problemaVisionAudicion) { %>
            <div class="warning-block" style="margin-top:10px;">
              <p class="warning-label">Visión / Audición</p>
              <p class="warning-value"><%= locals.cuidadoPersonal.problemaVisionAudicion %></p>
            </div>
          <% } %>

        </div>
      </div>

    </div>


    <!-- ══ COMUNICACIÓN + EMOCIONES ══ -->
    <div class="two-col">

      <div class="section-card">
        <div class="section-header">
          <div class="section-header-icon">
            <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
          </div>
          <span class="section-title">Perfil de Comunicación</span>
        </div>
        <div class="section-body">

          <% if (locals.perfilComunicacion?.idiomas) { %>
            <div class="field-group">
              <p class="field-label">Lenguajes que habla</p>
              <span class="comm-tag">
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
                <%= locals.perfilComunicacion.idiomas %>
              </span>
            </div>
          <% } %>

          <% if (locals.perfilComunicacion?.asistenteComunicacion) { %>
            <div class="field-group">
              <p class="field-label">Dispositivo o Asistente</p>
              <span class="comm-tag">
                <svg viewBox="0 0 24 24"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
                <%= locals.perfilComunicacion.asistenteComunicacion %>
              </span>
            </div>
          <% } %>

          <% if (locals.perfilComunicacion?.ayudaComunicacion) { %>
            <div class="info-block indigo">
              <div class="info-block-icon">
                <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
              </div>
              <div class="info-block-content">
                <p class="info-block-label">Pautas para comunicarse</p>
                <p class="info-block-value"><%= locals.perfilComunicacion.ayudaComunicacion %></p>
              </div>
            </div>
          <% } %>

          <div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:10px;">
            <% if (locals.perfilComunicacion?.necesitaAsistente) { %>
              <span class="comm-tag">
                <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                Necesita Asistente
              </span>
            <% } %>
            <% if (locals.perfilComunicacion?.personaApoyo) { %>
              <span class="comm-tag">
                <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
                Persona de Apoyo
              </span>
            <% } %>
          </div>

          <% if (!locals.perfilComunicacion) { %>
            <p class="empty-msg">No hay información de comunicación cargada.</p>
          <% } %>

        </div>
      </div>

      <div class="section-card">
        <div class="section-header">
          <div class="section-header-icon">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
          </div>
          <span class="section-title">Emociones y Gustos</span>
        </div>
        <div class="section-body">

          <%
            const emociones = [
              { titulo: 'Ansiedad',  clase: 'ansioso', valor: locals.emociones?.descripcionAnsioso },
              { titulo: 'Dolor',  clase: 'dolor',   valor: locals.emociones?.descripcionDolor },
              { titulo: 'Miedo',   clase: 'miedo',   valor: locals.emociones?.descripcionAsustado },
              { titulo: 'Enojo',   clase: 'enojo',   valor: locals.emociones?.descripcionEnojado }
            ];
            const hayEmociones = emociones.some(e => e.valor);
          %>

          <% if (hayEmociones || locals.emociones?.loQueMeGusta || locals.emociones?.loQueNoMeGusta) { %>
            <div class="emotions-grid">

              <% emociones.forEach(emo => { %>
                <% if (emo.valor) { %>
                  <div class="emotion-item <%= emo.clase %>">
                    <p class="emotion-label"><%= emo.titulo %></p>
                    <p class="emotion-desc"><%= emo.valor %></p>
                  </div>
                <% } %>
              <% }) %>

              <% if (locals.emociones?.loQueMeGusta) { %>
                <div class="emotion-item gusta emotion-full">
                  <p class="emotion-label">Cosas que le gustan</p>
                  <p class="emotion-desc"><%= locals.emociones.loQueMeGusta %></p>
                </div>
              <% } %>

              <% if (locals.emociones?.loQueNoMeGusta) { %>
                <div class="emotion-item nogusta emotion-full">
                  <p class="emotion-label">Cosas que le disgustan / molestan</p>
                  <p class="emotion-desc"><%= locals.emociones.loQueNoMeGusta %></p>
                </div>
              <% } %>

            </div>
          <% } else { %>
            <p class="empty-msg">No hay registros de emociones o gustos cargados.</p>
          <% } %>

        </div>
      </div>

    </div>


    <!-- ══ ESTUDIOS Y DOCUMENTOS ══ -->
    <div class="section-card">
      <div class="section-header">
        <div class="section-header-icon">
          <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        </div>
        <span class="section-title">Estudios y Documentos</span>
      </div>
      <div class="section-body">
        <% if (locals.historial?.archivosAdjuntos && locals.historial.archivosAdjuntos.length > 0) { %>
          <% const ultimosArchivos = locals.historial.archivosAdjuntos.slice(0, 3); %>
          <% ultimosArchivos.forEach(archivo => { %>
            <div class="file-row">
              <div class="file-ext"><%= archivo.url.split('.').pop() %></div>
              <div style="flex:1;min-width:0;">
                <p class="file-name"><%= archivo.nombreArchivo %></p>
                <p class="file-date"><%= new Date(archivo.fechaCarga).toLocaleDateString('es-AR') %></p>
              </div>
              <a href="<%= archivo.url %>" target="_blank" rel="noopener noreferrer" class="file-link" title="Ver archivo">
                <svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              </a>
            </div>
          <% }) %>
        <% } else { %>
          <p class="empty-msg">No hay documentos recientes.</p>
        <% } %>
        <a href="/pacientes/<%= locals.paciente.userId %>/historial-archivos" class="btn-primary">
            Ver todos los documentos
        </a>
      </div>
    </div>

  </div>
</div>
