<style>
  @media print {
    body { background-color: white !important; }
    .print-oculto { display: none !important; }
    .shadow-sm, .shadow-md { box-shadow: none !important; }
    .border-slate-200 { border-color: #e2e8f0 !important; }
  }
</style>

<div class="min-h-screen bg-slate-100 px-4 py-8 md:py-12">
  <div class="max-w-4xl mx-auto space-y-6">

    <div class="flex justify-end print-oculto mb-4">
      <button onclick="window.print()" class="flex items-center gap-2 bg-white border border-slate-300 text-slate-700 px-5 py-2.5 rounded-xl font-bold shadow-sm hover:bg-slate-50 transition-all">
        <span class="text-xl">🖨️</span> Imprimir Pasaporte
      </button>
    </div>

    <div class="bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden">

      <div class="bg-slate-800 px-6 py-8 sm:px-10 text-white">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
          <div>
            <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight">
              <%= locals.usuarioPaciente?.nombre %> <%= locals.usuarioPaciente?.apellido %>
            </h1>
            <div class="flex flex-wrap items-center gap-3 mt-4 text-slate-300 text-sm md:text-base font-medium">
              <% if (locals.paciente?.apodo) { %>
                <span class="bg-slate-700 px-3 py-1.5 rounded-lg text-white font-bold">"<%= locals.paciente.apodo %>"</span>
              <% } %>
              <% if (locals.paciente?.dni) { %>
                <span class="flex items-center gap-1.5 bg-slate-700/50 px-3 py-1.5 rounded-lg">
                  <span class="text-slate-400 text-xs uppercase tracking-wider">DNI</span> <%= locals.paciente.dni %>
                </span>
              <% } %>
              <% if (locals.paciente?.nroObraSocial) { %>
                <span class="flex items-center gap-1.5 bg-slate-700/50 px-3 py-1.5 rounded-lg">
                  <span class="text-slate-400 text-xs uppercase tracking-wider">O. Social</span> <%= locals.paciente.nroObraSocial %>
                </span>
              <% } %>
              <% if (locals.paciente?.fechaNacimiento) { %>
                <span class="flex items-center gap-1.5 bg-slate-700/50 px-3 py-1.5 rounded-lg">
                  <span class="text-slate-400 text-xs uppercase tracking-wider">Nacimiento</span> <%= new Date(locals.paciente.fechaNacimiento).toLocaleDateString('es-AR') %>
                </span>
              <% } %>
            </div>
          </div>
        </div>
      </div>

      <% const tieneEpilepsia = locals.historial?.tieneEpilepsia; %>
      <% const tieneAlergias = locals.historial?.alergias && locals.historial.alergias.trim() !== ''; %>

      <% if (tieneEpilepsia || tieneAlergias) { %>
        <div class="px-6 py-6 sm:px-10 bg-red-50 border-b-4 border-red-500 flex flex-col gap-4">
          <h2 class="text-xs font-black text-red-600 uppercase tracking-widest">⚠️ Alertas Médicas Críticas</h2>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <% if (tieneEpilepsia) { %>
              <div class="bg-white rounded-xl p-4 border border-red-200 shadow-sm flex items-start gap-3">
                <span class="text-3xl">🧠</span>
                <div>
                  <h3 class="font-extrabold text-red-700 text-lg">Paciente con Epilepsia</h3>
                  <p class="text-red-900 text-sm mt-1 font-medium"><span class="font-bold text-red-700">Crisis:</span> <%= locals.historial?.tipoCrisis || 'No especificado' %></p>
                </div>
              </div>
            <% } %>

            <% if (tieneAlergias) { %>
              <div class="bg-white rounded-xl p-4 border border-red-200 shadow-sm flex items-start gap-3">
                <span class="text-3xl">🚫</span>
                <div>
                  <h3 class="font-extrabold text-red-700 text-lg">Alergias Reportadas</h3>
                  <p class="text-red-900 text-sm mt-1 font-medium"><%= locals.historial.alergias %></p>
                </div>
              </div>
            <% } %>
          </div>
        </div>
      <% } %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 break-inside-avoid">

      <div class="bg-white rounded-3xl p-6 sm:p-8 shadow-sm border border-slate-200">
        <h2 class="text-xl font-extrabold text-slate-800 mb-5 flex items-center gap-2">
          <span class="text-2xl">🚨</span> Contactos de Emergencia
        </h2>

        <div class="space-y-3">
          <% if (locals.paciente?.contactos?.length > 0) { %>
            <% locals.paciente.contactos.forEach(c => { %>
              <div class="bg-orange-50 rounded-2xl p-4 border border-orange-100 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                <div>
                  <p class="font-bold text-slate-800 text-lg"><%= c.nombre %></p>
                  <p class="text-orange-700 font-medium text-sm mt-0.5"><%= c.relacion || 'Familiar' %></p>
                </div>
                <div class="text-left sm:text-right">
                  <a href="tel:<%= c.telefono %>" class="print-oculto inline-flex items-center gap-2 bg-white text-orange-600 border border-orange-200 px-4 py-2 rounded-xl font-bold hover:bg-orange-600 hover:text-white transition-colors shadow-sm">
                    📞 Llamar
                  </a>
                  <p class="text-sm text-slate-800 sm:text-slate-500 mt-2 font-bold sm:font-medium"><%= c.telefono %></p>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <p class="text-slate-500 font-medium bg-slate-50 p-4 rounded-xl text-center">No hay contactos registrados.</p>
          <% } %>
        </div>
      </div>

      <div class="bg-white rounded-3xl p-6 sm:p-8 shadow-sm border border-slate-200">
        <h2 class="text-xl font-extrabold text-slate-800 mb-5 flex items-center gap-2">
          <span class="text-2xl">👨‍⚕️</span> Médico Tratante
        </h2>

        <% if (locals.paciente?.medicoCabecera) { %>
          <div class="bg-emerald-50 rounded-2xl p-5 border border-emerald-100 h-full">
            <h3 class="font-black text-emerald-900 text-xl"><%= locals.paciente.medicoCabecera.nombre %> <%= locals.paciente.medicoCabecera.apellido %></h3>
            <div class="mt-5 space-y-4">
              <% if (locals.paciente.medicoCabecera.telefono) { %>
                <div>
                  <p class="text-xs font-bold text-emerald-700 uppercase tracking-wider mb-1">📞 Teléfono de contacto</p>
                  <p class="font-bold text-slate-800 text-lg"><%= locals.paciente.medicoCabecera.telefono %></p>
                </div>
              <% } %>
              <% if (locals.paciente.medicoCabecera.direccion) { %>
                <div>
                  <p class="text-xs font-bold text-emerald-700 uppercase tracking-wider mb-1">📍 Consultorio</p>
                  <p class="font-medium text-slate-800"><%= locals.paciente.medicoCabecera.direccion %></p>
                </div>
              <% } %>
            </div>
          </div>
        <% } else { %>
          <p class="text-slate-500 font-medium bg-slate-50 p-4 rounded-xl text-center h-full flex items-center justify-center">No hay médico registrado.</p>
        <% } %>
      </div>
    </div>

    <div class="bg-white rounded-3xl p-6 sm:p-8 shadow-sm border border-slate-200 break-inside-avoid">
      <h2 class="text-xl font-extrabold text-slate-800 mb-6 flex items-center gap-2">
        <span class="text-2xl">💊</span> Medicación Actual
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <% if (locals.historial?.medicamentos?.length > 0) { %>
          <% locals.historial.medicamentos.forEach(med => { %>
            <div class="bg-slate-50 rounded-2xl p-5 border border-slate-200 flex flex-col justify-between">
              <h4 class="text-lg font-extrabold text-slate-800 mb-4 border-b border-slate-200 pb-3">
                <%= med.medicamento?.nombre || med.medicamentoPersonalizado || 'Sin nombre' %>
              </h4>
              <div class="grid grid-cols-2 gap-y-4 gap-x-2">
                <div>
                  <span class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-0.5">Dosis</span>
                  <span class="font-bold text-slate-700 text-sm"><%= med.dosis || '-' %></span>
                </div>
                <div>
                  <span class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-0.5">Forma</span>
                  <span class="font-bold text-slate-700 text-sm"><%= med.formaMedicamento || '-' %></span>
                </div>
                <div>
                  <span class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-0.5">Horarios</span>
                  <span class="font-bold text-indigo-600 text-sm"><%= med.horarios || '-' %></span>
                </div>
                <div>
                  <span class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-0.5">Ingesta</span>
                  <span class="font-bold text-slate-700 text-sm"><%= med.momentoIngesta || '-' %></span>
                </div>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="col-span-full bg-slate-50 rounded-2xl p-6 text-center border-2 border-dashed border-slate-200">
            <p class="text-base font-medium text-slate-500">No requiere medicación registrada.</p>
          </div>
        <% } %>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

      <div class="bg-white rounded-3xl p-6 shadow-sm border border-slate-200 break-inside-avoid">
        <h2 class="text-lg font-bold text-slate-800 mb-4 flex items-center gap-2 border-b pb-3 border-slate-100">
          <span class="text-xl">📋</span> Historial Clínico Extra
        </h2>
        <div class="space-y-4">
          <% if (locals.historial?.metodosIntervencion) { %>
            <div>
              <p class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Intervenciones Previas</p>
              <p class="text-sm font-medium text-slate-800 bg-slate-50 p-3 rounded-xl border border-slate-100"><%= locals.historial.metodosIntervencion %></p>
            </div>
          <% } %>
          <% if (locals.historial?.datosExtras) { %>
            <div>
              <p class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Datos Extras Relevantes</p>
              <p class="text-sm font-medium text-slate-800 bg-slate-50 p-3 rounded-xl border border-slate-100"><%= locals.historial.datosExtras %></p>
            </div>
          <% } %>
          <% if (locals.paciente?.necesidadesReligiosas) { %>
            <div>
              <p class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Necesidades Religiosas</p>
              <p class="text-sm font-medium text-slate-800 bg-slate-50 p-3 rounded-xl border border-slate-100"><%= locals.paciente.necesidadesReligiosas %></p>
            </div>
          <% } %>
          <% if (!locals.historial?.metodosIntervencion && !locals.historial?.datosExtras && !locals.paciente?.necesidadesReligiosas) { %>
            <p class="text-sm text-slate-400 italic">No hay información extra cargada.</p>
          <% } %>
        </div>
      </div>

      <div class="bg-white rounded-3xl p-6 shadow-sm border border-slate-200 break-inside-avoid">
        <h2 class="text-lg font-bold text-slate-800 mb-4 flex items-center gap-2 border-b pb-3 border-slate-100">
          <span class="text-xl">🦽</span> Cuidado y Movilidad
        </h2>
        <div class="space-y-4">
          <% if (locals.cuidadoPersonal?.tipoMovilidad) { %>
            <div>
              <p class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Tipo de Movilidad</p>
              <p class="text-sm font-bold text-violet-700 bg-violet-50 px-3 py-2 rounded-xl border border-violet-100 inline-block"><%= locals.cuidadoPersonal.tipoMovilidad %></p>
            </div>
          <% } %>
          <% if (locals.historial?.metodoLiquidosSolidos) { %>
            <div>
              <p class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Ingesta de Líquidos/Sólidos</p>
              <p class="text-sm font-medium text-slate-800 bg-slate-50 p-3 rounded-xl border border-slate-100"><%= locals.historial.metodoLiquidosSolidos %></p>
            </div>
          <% } %>
          <% if (locals.cuidadoPersonal?.cuidadoPersonal || locals.cuidadoPersonal?.usoBano) { %>
            <div>
              <p class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Asistencia en Higiene</p>
              <p class="text-sm font-medium text-slate-800 bg-slate-50 p-3 rounded-xl border border-slate-100">
                <%= [locals.cuidadoPersonal?.cuidadoPersonal, locals.cuidadoPersonal?.usoBano].filter(Boolean).join(' | ') %>
              </p>
            </div>
          <% } %>
        </div>
      </div>

      <div class="bg-white rounded-3xl p-6 shadow-sm border border-slate-200 break-inside-avoid">
        <h2 class="text-lg font-bold text-slate-800 mb-4 flex items-center gap-2 border-b pb-3 border-slate-100">
          <span class="text-xl">🗣️</span> Perfil de Comunicación
        </h2>
        <div class="space-y-4">
          <% if (locals.perfilComunicacion?.asistenteComunicacion) { %>
            <div>
              <p class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Dispositivo o Asistente utilizado</p>
              <p class="text-sm font-bold text-amber-700 bg-amber-50 px-3 py-2 rounded-xl border border-amber-100 inline-block"><%= locals.perfilComunicacion.asistenteComunicacion %></p>
            </div>
          <% } %>
          <% if (locals.perfilComunicacion?.ayudaComunicacion) { %>
            <div>
              <p class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Pautas para comunicarse con el paciente</p>
              <p class="text-sm font-medium text-slate-800 bg-slate-50 p-3 rounded-xl border border-slate-100"><%= locals.perfilComunicacion.ayudaComunicacion %></p>
            </div>
          <% } %>
          <% if (!locals.perfilComunicacion?.asistenteComunicacion && !locals.perfilComunicacion?.ayudaComunicacion) { %>
             <p class="text-sm text-slate-400 italic">No hay información de comunicación cargada.</p>
          <% } %>
        </div>
      </div>

      <div class="bg-white rounded-3xl p-6 shadow-sm border border-slate-200 break-inside-avoid">
        <h2 class="text-lg font-bold text-slate-800 mb-4 flex items-center gap-2 border-b pb-3 border-slate-100">
          <span class="text-xl">🧠</span> Indicadores Conductuales
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <% const emociones = [
            { titulo: 'Ansiedad', icono: '😰', valor: locals.emociones?.descripcionAnsioso },
            { titulo: 'Dolor', icono: '🤕', valor: locals.emociones?.descripcionDolor },
            { titulo: 'Miedo', icono: '😨', valor: locals.emociones?.descripcionAsustado },
            { titulo: 'Enojo', icono: '😠', valor: locals.emociones?.descripcionEnojado }
          ]; %>

          <% emociones.forEach(emo => { %>
            <% if (emo.valor) { %>
              <div class="bg-pink-50 rounded-xl p-3 border border-pink-100">
                <p class="text-xs font-bold text-pink-700 uppercase tracking-wider mb-1"><%= emo.icono %> <%= emo.titulo %></p>
                <p class="text-sm font-medium text-slate-800 leading-tight"><%= emo.valor %></p>
              </div>
            <% } %>
          <% }) %>

          <% if (!emociones.some(e => e.valor)) { %>
            <div class="col-span-full">
              <p class="text-sm text-slate-400 italic">No hay indicadores de conducta cargados.</p>
            </div>
          <% } %>
        </div>
      </div>

    </div>

  </div>
</div>
