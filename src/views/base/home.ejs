<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <header class="mb-10 border-b border-slate-200 pb-6">
    <h1 class="text-3xl font-light text-slate-900 tracking-tight">
      Bienvenido, <span class="font-medium"><%= locals.user ? locals.user.nombre : '' %></span>
    </h1>
    <p class="mt-2 text-slate-500">
      <% if (locals.user && locals.user.rolNombre === 'PACIENTE') { %>
        Panel personal de salud
      <% } else if (locals.user && (locals.user.rolNombre === 'MEDICO' || locals.user.rolNombre === 'ENFERMERO')) { %>
        Panel de gestión médica
      <% } else { %>
        Panel de administración general
      <% } %>
    </p>
  </header>

  <section class="bg-white rounded-xl border border-slate-200 p-8 shadow-sm">
    <p class="text-slate-600">Este es tu espacio principal. Navegá por el menú superior para ver tus opciones.</p>
  </section>
</div>
