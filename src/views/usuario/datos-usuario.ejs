<div class="max-w-4xl mx-auto space-y-6">

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-r-xl shadow-sm">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <p class="text-sm text-red-700 font-medium">
            <%= error %>
          </p>
        </div>
      </div>
    </div>
  <% } %>

  <% if (typeof success !== 'undefined' && success) { %>
    <div class="bg-green-50 border-l-4 border-green-500 p-4 rounded-r-xl shadow-sm">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-green-500" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <p class="text-sm text-green-700 font-medium">
            <%= success %>
          </p>
        </div>
      </div>
    </div>
  <% } %>

  <div class="bg-white border border-slate-200 rounded-2xl shadow-sm p-6 md:p-8">
    <div class="mb-6 border-b border-slate-100 pb-4">
      <h1 class="text-xl font-bitter text-slate-800 tracking-tight">Datos de la cuenta</h1>
    </div>

    <form action="/perfil/actualizar-datos?_method=PUT" method="POST" class="space-y-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label for="nombre" class="block text-sm font-medium text-slate-700 mb-2">Nombre</label>
          <input type="text" id="nombre" name="nombre" value="<%= user.nombre %>" required
            class="w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-slate-50 focus:bg-white focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all">
        </div>

        <div>
          <label for="apellido" class="block text-sm font-medium text-slate-700 mb-2">Apellido</label>
          <input type="text" id="apellido" name="apellido" value="<%= user.apellido %>" required
            class="w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-slate-50 focus:bg-white focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all">
        </div>
      </div>

      <div>
        <label for="email" class="block text-sm font-medium text-slate-700 mb-2">Correo electrónico</label>
        <input type="email" id="email" value="<%= user.email %>" readonly disabled
          class="w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-slate-100 text-slate-500 cursor-not-allowed outline-none">
        <p class="mt-2 text-xs text-slate-500">El correo electrónico no se puede modificar.</p>
      </div>

      <% if (user.rolNombre === 'MEDICO') { %>
        <div class="bg-indigo-50 rounded-xl p-4 border border-indigo-100 mb-6">
          <label class="block text-sm font-bold text-indigo-900 mb-1">Especialidad Médica</label>
          <div class="flex items-center gap-2 mt-1">
            <p class="text-indigo-700 text-sm font-medium">
              <%= especialidadMedica || 'No especificada' %>
            </p>
          </div>
        </div>
      <% } %>

      <% if (user.rolNombre === 'ACOMPAÑANTE') { %>
        <div class="bg-teal-50 rounded-xl p-4 border border-teal-100 mb-6">
          <label class="block text-sm font-bold text-teal-900 mb-1">Paciente Asociado</label>
          <div class="flex items-center gap-2 mt-1">
            <p class="text-teal-700 text-sm font-medium">
              <%= nombrePacienteAsociado || 'Sin paciente vinculado' %>
            </p>
          </div>
        </div>
      <% } %>

      <div class="pt-4 flex justify-end">
        <button type="submit" class="px-6 py-2.5 bg-colorAzulFundacion text-white text-sm font-bitter rounded-xl hover:bg-slate-900 transition-all shadow-sm focus:outline-none focus:ring-2 focus:ring-slate-500 focus:ring-offset-2">
          Guardar datos
        </button>
      </div>
    </form>
  </div>

  <div class="bg-white border border-slate-200 rounded-2xl shadow-sm p-6 md:p-8">
    <div class="mb-6 border-b border-slate-100 pb-4">
      <h2 class="text-xl font-bitter text-slate-800 tracking-tight">Seguridad</h2>
      <p class="text-sm text-slate-500 mt-1">Modificá tu contraseña de acceso al sistema.</p>
    </div>

    <form action="/perfil/actualizar-contrasena?_method=PUT" method="POST" class="space-y-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label for="nuevaPassword" class="block text-sm font-medium text-slate-700 mb-2">Nueva contraseña</label>
          <div class="relative">
            <input type="password" id="nuevaPassword" name="nuevaPassword" required minlength="8" placeholder="Mínimo 8 caracteres"
              class="w-full pl-4 pr-10 py-2.5 rounded-xl border border-slate-200 bg-slate-50 focus:bg-white focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all">
            <button type="button" id="btnToggleNueva" aria-label="Mostrar nueva contraseña" class="absolute inset-y-0 right-0 pr-3 flex items-center text-slate-400 hover:text-slate-600 focus:outline-none">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
            </button>
          </div>
        </div>

        <div>
          <label for="confirmarPassword" class="block text-sm font-medium text-slate-700 mb-2">Confirmar contraseña</label>
          <div class="relative">
            <input type="password" id="confirmarPassword" name="confirmarPassword" required minlength="8" placeholder="Repetí la contraseña"
              class="w-full pl-4 pr-10 py-2.5 rounded-xl border border-slate-200 bg-slate-50 focus:bg-white focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all">
            <button type="button" id="btnToggleConfirmar" aria-label="Mostrar confirmacion de la contraseña" class="absolute inset-y-0 right-0 pr-3 flex items-center text-slate-400 hover:text-slate-600 focus:outline-none">
               <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
            </button>
          </div>
        </div>
      </div>

      <div class="pt-4 flex justify-end">
        <button type="submit" class="px-6 py-2.5 bg-colorAzulFundacion text-white text-sm font-bitter rounded-xl hover:bg-slate-900 transition-all shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2">
          Cambiar contraseña
        </button>
      </div>
    </form>
  </div>

</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const configurarTogglePassword = (inputId, btnId) => {
      const input = document.getElementById(inputId);
      const btn = document.getElementById(btnId);

      if (input && btn) {
        btn.addEventListener('click', () => {
          const tipoActual = input.getAttribute('type');
          const nuevoTipo = tipoActual === 'password' ? 'text' : 'password';
          input.setAttribute('type', nuevoTipo);

          if (nuevoTipo === 'text') {
            btn.innerHTML = `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" /></svg>`;
          } else {
            btn.innerHTML = `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>`;
          }
        });
      }
    };

    configurarTogglePassword('nuevaPassword', 'btnToggleNueva');
    configurarTogglePassword('confirmarPassword', 'btnToggleConfirmar');
  });
</script>
