<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Recuperar Contraseña - ONG Pasaporte</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-slate-100 font-sans">

  <div class="min-h-screen flex items-center justify-center p-4">

    <div class="w-full max-w-md mx-auto bg-white rounded-3xl shadow-sm border border-slate-200 p-8 sm:p-10">
      <div class="text-center mb-8">
        <div class="w-16 h-16 bg-indigo-50 rounded-2xl flex items-center justify-center mx-auto mb-4 border border-indigo-100">
          <svg class="w-8 h-8 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path></svg>
        </div>
        <h1 class="text-2xl font-extrabold text-slate-800">Recuperar contraseña</h1>
        <p class="text-sm text-slate-500 mt-2">Ingresá el correo electrónico asociado a tu cuenta y te enviaremos un enlace para restablecerla.</p>
      </div>

      <form id="form-olvide" class="space-y-6">
        <div>
          <label for="email" class="block text-sm font-semibold text-slate-700 mb-2">Correo electrónico</label>
          <input type="email" id="email" name="email" required
            class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-slate-800 focus:bg-white focus:ring-4 focus:ring-indigo-50 focus:border-indigo-500 outline-none transition-all"
            placeholder="tu@correo.com">
        </div>

        <div id="mensaje-box" class="hidden rounded-xl p-4 text-sm font-medium text-center"></div>

        <button type="submit" id="btn-submit" class="w-full py-3.5 bg-slate-800 hover:bg-slate-900 text-white text-base font-bold rounded-xl transition-all shadow-md active:scale-95 focus:outline-none focus:ring-2 focus:ring-slate-500 focus:ring-offset-2">
          Enviar enlace de recuperación
        </button>
      </form>

      <div class="mt-8 text-center">
        <a href="/auth/login" class="text-lg font-bitter text-colorAzulFundacion hover:text-slate-900 transition-colors">
          &larr; Volver al inicio de sesión
        </a>
      </div>
    </div>

  </div>

  <script>
    document.getElementById('form-olvide').addEventListener('submit', async (e) => {
      e.preventDefault();

      const btn = document.getElementById('btn-submit');
      const mensajeBox = document.getElementById('mensaje-box');
      const email = document.getElementById('email').value;

      btn.textContent = 'Enviando...';
      btn.disabled = true;
      mensajeBox.classList.add('hidden');

      try {
        const res = await fetch('/auth/recuperar-contrasena', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email })
        });

        const data = await res.json();

        if (!res.ok) throw new Error(data.mensaje || 'Error al enviar el correo');

        mensajeBox.textContent = data.mensaje;
        mensajeBox.className = 'rounded-xl p-4 text-sm font-medium text-center bg-green-50 text-green-700 border border-green-200';
        mensajeBox.classList.remove('hidden');
        document.getElementById('email').value = '';

      } catch (error) {
        mensajeBox.textContent = error.message;
        mensajeBox.className = 'rounded-xl p-4 text-sm font-medium text-center bg-red-50 text-red-700 border border-red-200';
        mensajeBox.classList.remove('hidden');
      } finally {
        btn.textContent = 'Enviar enlace de recuperación';
        btn.disabled = false;
      }
    });
  </script>
</body>
</html>
