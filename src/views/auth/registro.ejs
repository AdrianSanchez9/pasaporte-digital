<div class="flex items-center justify-center min-h-[calc(100vh-4rem)] px-4 py-12">
  <div class="bg-white p-8 md:p-10 rounded-3xl shadow-sm border border-slate-200 w-full max-w-2xl">

    <div class="text-center mb-10">
      <h2 class="text-3xl font-bold text-slate-800 tracking-tight">Crear Cuenta</h2>
      <p class="text-slate-500 text-sm mt-2">Registra un nuevo usuario en Pasaporte Médico</p>
    </div>

    <% if (locals.error) { %>
      <div class="bg-red-50 border-l-4 border-red-500 text-red-700 p-4 mb-8 rounded-r-xl" role="alert">
        <p class="text-sm font-medium"><%= locals.error %></p>
      </div>
    <% } %>

    <form action="/auth/registro" method="POST" class="space-y-6">

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label for="nombre" class="block text-sm font-medium text-slate-700 mb-2">Nombre</label>
          <input type="text" id="nombre" name="nombre" required
            value="<%= locals.formData ? locals.formData.nombre : '' %>"
            class="w-full px-4 py-3 rounded-2xl border border-slate-200 bg-slate-50 focus:bg-white focus:ring-1 focus:ring-slate-400 focus:border-slate-400 outline-none transition-all"
            placeholder="Ej: Juan">
        </div>

        <div>
          <label for="apellido" class="block text-sm font-medium text-slate-700 mb-2">Apellido</label>
          <input type="text" id="apellido" name="apellido" required
            value="<%= locals.formData ? locals.formData.apellido : '' %>"
            class="w-full px-4 py-3 rounded-2xl border border-slate-200 bg-slate-50 focus:bg-white focus:ring-1 focus:ring-slate-400 focus:border-slate-400 outline-none transition-all"
            placeholder="Ej: Pérez">
        </div>

        <div class="md:col-span-2">
          <label for="rolNombre" class="block text-sm font-medium text-slate-700 mb-2">Rol del Usuario</label>
          <select id="rolNombre" name="rolNombre" required
            class="w-full px-4 py-3 rounded-2xl border border-slate-200 bg-slate-50 focus:bg-white focus:ring-1 focus:ring-slate-400 focus:border-slate-400 outline-none transition-all cursor-pointer">
            <option value="" disabled selected>Selecciona un rol</option>
            <option value="PACIENTE">Paciente</option>
            <option value="MEDICO">Médico</option>
            <option value="ACOMPANANTE">Acompañante</option>
            <option value="ADMIN">Administrador</option>
            <option value="USUARIO_EXTERNO">Usuario externo</option>
          </select>
        </div>

        <div id="campo-especialidad" style="display:none">
          <label for="especialidad" class="block text-sm font-medium text-slate-700 mb-2">Especialidad Médica</label>
          <input type="text" id="especialidad" name="especialidad"
            value="<%= locals.formData ? locals.formData.especialidad : '' %>"
            class="w-full px-4 py-3 rounded-2xl border border-slate-200 bg-slate-50 focus:bg-white focus:ring-1 focus:ring-slate-400 focus:border-slate-400 outline-none transition-all"
            placeholder="Ej: Cardiología, Pediatría...">
        </div>

        <div id="campo-paciente" style="display:none">
          <label for="pacienteInput" class="block text-sm font-medium text-slate-700 mb-2">Asignar Paciente</label>
          <input list="pacientesList" id="pacienteInput" name="pacienteAsignado"
            class="w-full px-4 py-3 rounded-2xl border border-slate-200 bg-slate-50 focus:bg-white focus:ring-1 focus:ring-slate-400 focus:border-slate-400 outline-none transition-all"
            placeholder="Escribe para buscar por nombre o apellido...">
          <datalist id="pacientesList">
            <% if (locals.pacientes) { %>
              <% pacientes.forEach(p => { %>
                <option value="<%= p.nombre %> <%= p.apellido %>">
              <% }) %>
            <% } %>
          </datalist>
        </div>
      </div>

      <hr class="border-slate-100">

      <div class="space-y-6">
        <div>
          <label for="email" class="block text-sm font-medium text-slate-700 mb-2">Correo Electrónico</label>
          <input type="email" id="email" name="email" required
            value="<%= locals.formData ? locals.formData.email : '' %>"
            class="w-full px-4 py-3 rounded-2xl border border-slate-200 bg-slate-50 focus:bg-white focus:ring-1 focus:ring-slate-400 focus:border-slate-400 outline-none transition-all"
            placeholder="ejemplo@correo.com">
        </div>

        <div>
          <label for="password" class="block text-sm font-medium text-slate-700 mb-2">Contraseña</label>
          <div class="relative">
            <input type="password" id="password" name="password" required
              class="w-full px-4 py-3 rounded-2xl border border-slate-200 bg-slate-50 focus:bg-white focus:ring-1 focus:ring-slate-400 focus:border-slate-400 outline-none transition-all pr-12"
              placeholder="Mínimo 8 caracteres">
            <button type="button" id="togglePassword"
              class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 transition-colors">
              <svg id="iconoOjo" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
            </button>
          </div>
        </div>
      </div>

      <button type="submit"
        class="w-full bg-slate-800 hover:bg-slate-900 text-white font-semibold py-4 rounded-2xl transition-all shadow-md active:scale-[0.98] mt-4">
        Finalizar Registro
      </button>
    </form>
  </div>
  <div id="modalExito" class="fixed inset-0 z-50 flex items-center justify-center hidden">
    <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm"></div>

    <div class="relative bg-white p-8 rounded-3xl shadow-2xl border border-slate-100 w-full max-w-sm text-center animate-in fade-in zoom-in duration-300">
      <div class="inline-flex items-center justify-center w-16 h-16 bg-emerald-100 text-emerald-600 rounded-full mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>

      <h3 class="text-xl font-bold text-slate-800 mb-2">¡Usuario Creado!</h3>
      <p class="text-slate-500 text-sm mb-6">El registro se completó con éxito. Puedes continuar cargando más usuarios.</p>

      <button id="btnCerrarModal"
        class="w-full bg-slate-800 hover:bg-slate-900 text-white font-medium py-3 rounded-xl transition-all shadow-sm active:scale-95">
        Entendido
      </button>
    </div>
  </div>
</div>

<script>

document.addEventListener('DOMContentLoaded', () => {
    const modal = document.getElementById('modalExito');

    if (new URLSearchParams(window.location.search).get('success') === 'true') {
      modal.classList.remove('hidden');
      window.history.replaceState({}, document.title, window.location.pathname);
    }

    document.getElementById('btnCerrarModal')?.addEventListener('click', () => {
      modal.classList.add('hidden');
    });
  });




document.getElementById('rolNombre').addEventListener('change', function() {
  const rol = this.value;
  const campoEspecialidad = document.getElementById('campo-especialidad');
  const campoPaciente = document.getElementById('campo-paciente');

  campoEspecialidad.style.display = 'none';
  campoPaciente.style.display = 'none';

  if (rol === 'MEDICO') {
    campoEspecialidad.style.display = 'block';
  } else if (rol === 'ACOMPANANTE') {
    campoPaciente.style.display = 'block';
  }
});

document.getElementById('togglePassword').addEventListener('click', function() {
  const input = document.getElementById('password');
  const icono = document.getElementById('iconoOjo');
  const esPassword = input.type === 'password';

  input.type = esPassword ? 'text' : 'password';

  icono.innerHTML = esPassword
    ?
      `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
        d="M13.875 18.825A10.05 10.05 0 0112 19c-4.477 0-8.268-2.943-9.542-7a9.97 9.97 0 012.071-3.293M6.7 6.7A9.953 9.953 0 0112 5c4.477 0 8.268 2.943 9.542 7a9.97 9.97 0 01-1.337 2.463M6.7 6.7L3 3m3.7 3.7l10.6 10.6M3 3l18 18" />`
    :
      `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
        d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
       <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
        d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />`;
});
</script>
