            <div>
              <label class="block text-sm font-semibold text-slate-700 mb-2">Asistente de comunicación</label>
              <input type="text" name="asistenteComunicacion" value="<%= locals.perfilComunicacion?.asistenteComunicacion || '' %>"
                class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-base text-slate-800 focus:bg-white focus:ring-4 focus:ring-amber-50 focus:border-amber-400 outline-none transition-all"
