                  class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-base text-slate-800 focus:bg-white focus:ring-4 focus:ring-red-50 focus:border-red-400 outline-none transition-all resize-none"
                  placeholder="Describí tus alergias conocidas (medicamentos, alimentos, etc.)"><%= locals.historial?.alergias || '' %></textarea>
              </div>
              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Métodos de intervención</label>
                <textarea name="metodosIntervencion" rows="3"
                  class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-base text-slate-800 focus:bg-white focus:ring-4 focus:ring-red-50 focus:border-red-400 outline-none transition-all resize-none"
                  placeholder="Intervenciones quirúrgicas u otros procedimientos pasados"><%= locals.historial?.metodosIntervencion || '' %></textarea>
              </div>
              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Método de líquidos y sólidos</label>
                <textarea name="metodoLiquidosSolidos" rows="2"
