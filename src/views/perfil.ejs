<div class="min-h-screen bg-slate-50 px-4 py-10 md:py-16">


  <div class="max-w-4xl mx-auto">

    <div class="mb-10 text-center md:text-left">
        <h1 class="text-3xl font-bitter text-slate-800 tracking-tight">
            <% if (locals.user?.rolNombre === 'ACOMPAÑANTE') { %>
              Perfil del paciente asociado
            <% } else { %>
              Mi Perfil
            <% } %>
          </h1>
      <p class="text-slate-500 text-base mt-2">Gestioná tu información personal y médica de forma segura.</p>
    </div>

    <div id="toast" class="hidden fixed top-6 right-6 z-50 px-6 py-4 rounded-2xl shadow-xl text-sm font-bold transition-all border"></div>

    <div class="space-y-5">

      <div class="accordion-item bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden transition-all hover:border-slate-300">
        <button class="accordion-trigger w-full flex items-center justify-between px-6 py-6 text-left focus:outline-none focus:bg-slate-50">
          <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl bg-white flex items-center justify-center border border-violet-100 overflow-hidden">
                <img src="/img/datosin.png" alt="Ícono de datos paciente" class="w-12 h-12 object-contain drop-shadow-sm">
              </div>
            <span class="text-lg font-bold text-slate-800">Mis datos personales</span>
          </div>
          <svg class="accordion-chevron w-6 h-6 text-slate-400 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="accordion-content hidden px-6 pb-8 pt-2">
          <form id="form-datos-personales" class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">DNI</label>
                <input type="text" name="dni" value="<%= locals.paciente?.dni || '' %>"
                  class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-base text-slate-800 focus:bg-white focus:ring-4 focus:ring-blue-50 focus:border-blue-500 outline-none transition-all" placeholder="Ej: 12345678">
              </div>
              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Apodo</label>
                <input type="text" name="apodo" value="<%= locals.paciente?.apodo || '' %>"
                  class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-base text-slate-800 focus:bg-white focus:ring-4 focus:ring-blue-50 focus:border-blue-500 outline-none transition-all" placeholder="Como te llaman">
              </div>
              <div>
                <label for="fechaNacimiento" class="block text-sm font-semibold text-slate-700 mb-2">Fecha de nacimiento</label>
                <input type="date" id="fechaNacimiento" name="fechaNacimiento" value="<%= locals.paciente?.fechaNacimiento ? new Date(locals.paciente.fechaNacimiento).toISOString().split('T')[0] : '' %>"
                  class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-base text-slate-800 focus:bg-white focus:ring-4 focus:ring-blue-50 focus:border-blue-500 outline-none transition-all">
              </div>
              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Teléfono</label>
                <input type="tel" name="telefono" value="<%= locals.paciente?.telefono || '' %>"
                  class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-base text-slate-800 focus:bg-white focus:ring-4 focus:ring-blue-50 focus:border-blue-500 outline-none transition-all" placeholder="Ej: +54 9 11 1234-5678">
              </div>
              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Nro. Obra Social</label>
                <input type="text" name="nroObraSocial" value="<%= locals.paciente?.nroObraSocial || '' %>"
                  class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-base text-slate-800 focus:bg-white focus:ring-4 focus:ring-blue-50 focus:border-blue-500 outline-none transition-all" placeholder="Número de afiliado">
              </div>
              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Dirección</label>
                <input type="text" name="direccion" value="<%= locals.paciente?.direccion || '' %>"
                  class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-base text-slate-800 focus:bg-white focus:ring-4 focus:ring-blue-50 focus:border-blue-500 outline-none transition-all" placeholder="Calle, número, ciudad">
              </div>
              <div>
                <label for="nacionalidad" class="block text-sm font-semibold text-slate-700 mb-2">Nacionalidad</label>
                <input type="text" id="nacionalidad" name="nacionalidad" value="<%= locals.paciente?.nacionalidad || '' %>"
                  class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-base text-slate-800 focus:bg-white focus:ring-4 focus:ring-blue-50 focus:border-blue-500 outline-none transition-all">
              </div>
              <div class="md:col-span-2">
                <label for="selectReligion" class="block text-sm font-semibold text-slate-700 mb-2">Religión</label>
                <select name="religion" id="selectReligion"
                  class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-base text-slate-800 focus:bg-white focus:ring-4 focus:ring-violet-50 focus:border-violet-400 outline-none transition-all cursor-pointer">
                  <option value="">Seleccioná una opción...</option>
                  <option value="Católica"                <%= locals.paciente?.religion === 'Católica' ? 'selected' : '' %>>Católica</option>
                      <option value="Cristiana evangélica"    <%= locals.paciente?.religion === 'Cristiana evangélica' ? 'selected' : '' %>>Cristiana evangélica</option>
                      <option value="Cristiana protestante"   <%= locals.paciente?.religion === 'Cristiana protestante' ? 'selected' : '' %>>Cristiana protestante</option>
                      <option value="Judía"                   <%= locals.paciente?.religion === 'Judía' ? 'selected' : '' %>>Judía</option>
                      <option value="Islámica"                <%= locals.paciente?.religion === 'Islámica' ? 'selected' : '' %>>Islámica</option>
                      <option value="Budista"                 <%= locals.paciente?.religion === 'Budista' ? 'selected' : '' %>>Budista</option>
                      <option value="Hinduista"               <%= locals.paciente?.religion === 'Hinduista' ? 'selected' : '' %>>Hinduista</option>
                      <option value="Testigos de Jehová"      <%= locals.paciente?.religion === 'Testigos de Jehová' ? 'selected' : '' %>>Testigos de Jehová</option>
                      <option value="Mormona"                 <%= locals.paciente?.religion === 'Mormona' ? 'selected' : '' %>>Mormona</option>
                      <option value="Adventista"              <%= locals.paciente?.religion === 'Adventista' ? 'selected' : '' %>>Adventista</option>
                      <option value="Sin religión"            <%= locals.paciente?.religion === 'Sin religión' ? 'selected' : '' %>>Sin religión</option>
                      <option value="Otra"                    <%= locals.paciente?.religion === 'Otra' ? 'selected' : '' %>>Otra...</option>
                </select>

                <input type="text" name="religionPersonalizada" id="religionPersonalizada"
                  class="hidden mt-2 w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-base text-slate-800 focus:bg-white focus:ring-4 focus:ring-violet-50 focus:border-violet-400 outline-none transition-all"
                  placeholder="Escribí tu religión...">
              </div>

              <div class="md:col-span-2">
                <label class="block text-sm font-semibold text-slate-700 mb-2">Necesidades religiosas</label>
                <textarea name="necesidadesReligiosas" rows="3"
                  class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-base text-slate-800 focus:bg-white focus:ring-4 focus:ring-blue-50 focus:border-blue-500 outline-none transition-all resize-none"
                  placeholder="Descripción de necesidades o prácticas religiosas (opcional)"><%= locals.paciente?.necesidadesReligiosas || '' %></textarea>
              </div>
            </div>
            <div class="flex justify-end pt-6">
              <button type="submit" class="btn-guardar w-full md:w-auto px-8 py-3.5 bg-colorAzulFundacion hover:bg-slate-900 text-white text-base font-bitter rounded-xl transition-all shadow-md active:scale-95">
                Guardar datos personales
              </button>
            </div>
          </form>
        </div>
      </div>

      <div class="accordion-item bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden transition-all hover:border-slate-300">
        <button class="accordion-trigger w-full flex items-center justify-between px-6 py-6 text-left focus:outline-none focus:bg-slate-50">
          <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl bg-white flex items-center justify-center border border-violet-100 overflow-hidden">
                <img src="/img/medicoCabecerasin.png" alt="Ícono de medico" class="w-12 h-12 object-contain drop-shadow-sm">
              </div>
            <span class="text-lg font-bold text-slate-800">Médico de cabecera</span>
          </div>
          <svg class="accordion-chevron w-6 h-6 text-slate-400 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="accordion-content hidden px-6 pb-8 pt-2">
          <% if (locals.paciente?.medicoCabecera) { %>
            <div class="bg-emerald-50/50 border-2 border-emerald-100 rounded-2xl p-6 mb-8 flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
              <div>
                <h1 class="text-lg font-bold text-slate-800 mb-1 flex items-center gap-2">
                  <%= locals.paciente.medicoCabecera.nombre %> <%= locals.paciente.medicoCabecera.apellido %>
                </h1>
                <div class="space-y-1 mt-3">
                  <% if (locals.paciente.medicoCabecera.telefono) { %>
                    <p class="text-sm font-medium text-slate-600 flex items-center gap-2">
                      <svg class="w-4 h-4 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                      <%= locals.paciente.medicoCabecera.telefono %>
                    </p>
                  <% } %>
                  <% if (locals.paciente.medicoCabecera.direccion) { %>
                    <p class="text-sm font-medium text-slate-600 flex items-center gap-2">
                      <svg class="w-4 h-4 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                      <%= locals.paciente.medicoCabecera.direccion %>
                    </p>
                  <% } %>
                </div>
              </div>
              <button id="btn-editar-medico" class="w-full md:w-auto px-5 py-2.5 bg-white border border-slate-300 text-slate-700 text-sm font-bitter rounded-xl hover:bg-slate-50 transition-all shadow-sm">
                Editar información
              </button>
            </div>
          <% } %>

          <form id="form-medico-cabecera" class="space-y-6 <%= locals.paciente?.medicoCabecera ? 'hidden' : '' %>" data-medico-id="<%= locals.paciente?.medicoCabecera?.id || '' %>">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Nombre</label>
                <input type="text" name="nombre" value="<%= locals.paciente?.medicoCabecera?.nombre || '' %>"
                  class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-base text-slate-800 focus:bg-white focus:ring-4 focus:ring-emerald-50 focus:border-emerald-500 outline-none transition-all" placeholder="Nombre del médico">
              </div>
              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Apellido</label>
                <input type="text" name="apellido" value="<%= locals.paciente?.medicoCabecera?.apellido || '' %>"
                  class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-base text-slate-800 focus:bg-white focus:ring-4 focus:ring-emerald-50 focus:border-emerald-500 outline-none transition-all" placeholder="Apellido del médico">
              </div>
              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Teléfono</label>
                <input type="tel" name="telefono" value="<%= locals.paciente?.medicoCabecera?.telefono || '' %>"
                  class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-base text-slate-800 focus:bg-white focus:ring-4 focus:ring-emerald-50 focus:border-emerald-500 outline-none transition-all" placeholder="Teléfono de contacto">
              </div>
              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Dirección / Consultorio</label>
                <input type="text" name="direccion" value="<%= locals.paciente?.medicoCabecera?.direccion || '' %>"
                  class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-base text-slate-800 focus:bg-white focus:ring-4 focus:ring-emerald-50 focus:border-emerald-500 outline-none transition-all" placeholder="Dirección del consultorio">
              </div>
            </div>
            <div class="flex flex-col-reverse md:flex-row justify-end gap-3 pt-6">
              <% if (locals.paciente?.medicoCabecera) { %>
                <button type="button" id="btn-cancelar-medico" class="px-8 py-3.5 border-2 border-slate-200 text-slate-600 text-base font-bitter rounded-xl hover:bg-slate-50 hover:border-slate-300 transition-all text-center">
                  Cancelar
                </button>
              <% } %>
              <button type="submit" class="btn-guardar px-8 py-3.5 bg-colorAzulFundacion hover:bg-slate-900 text-white text-base font-bitter rounded-xl transition-all shadow-md active:scale-95 text-center">
                <%= locals.paciente?.medicoCabecera ? 'Guardar actualización' : 'Guardar médico' %>
              </button>
            </div>
          </form>
        </div>
      </div>

      <div class="accordion-item bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden transition-all hover:border-slate-300">
              <button class="accordion-trigger w-full flex items-center justify-between px-6 py-6 text-left focus:outline-none focus:bg-slate-50">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-xl bg-white flex items-center justify-center border border-violet-100 overflow-hidden">
                      <img src="/img/contactosin.png" alt="Ícono de cuidados" class="w-12 h-12 object-contain drop-shadow-sm">
                    </div>
                  <span class="text-lg font-bold text-slate-800">Contactos de emergencia</span>
                </div>
                <svg class="accordion-chevron w-6 h-6 shrink-0 text-slate-400 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div class="accordion-content hidden px-6 pb-8 pt-2">

                <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-6">
                  <h2 class="text-xl font-bold text-slate-800">Listado de contactos</h2>
                  <button id="btn-agregar-contacto" class="w-full sm:w-auto px-5 py-2.5 bg-colorAzulFundacion text-white font-bitter border border-slate-900 rounded-xl hover:bg-slate-900 transition-all flex items-center justify-center gap-2">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                    Agregar contacto
                  </button>
                </div>

                <div id="lista-contactos" class="grid grid-cols-1 gap-4 mb-4">
                  <% if (locals.paciente?.contactos?.length > 0) { %>
                    <% locals.paciente.contactos.forEach(c => { %>
                      <div class="contacto-item relative bg-white rounded-2xl p-5 md:p-6 border border-slate-200 shadow-sm hover:shadow-md transition-shadow" data-id="<%= c.id %>">

                        <div class="contacto-vista">
                          <div class="flex flex-col sm:flex-row justify-between items-start gap-4 mb-5">
                            <h3 class="text-lg font-extrabold text-slate-800 flex items-center gap-2">
                                <%= c.nombre %> (<%= c.relacion || '' %>)
                            </h3>
                            <div class="flex items-center gap-2 w-full sm:w-auto justify-end">
                              <button class="btn-editar-contacto px-4 py-2 bg-slate-50 hover:bg-slate-100 text-slate-700 font-bitter rounded-lg text-sm border border-slate-200 transition-all">Editar</button>
                              <button class="btn-eliminar-contacto group flex items-center gap-2 px-3 py-2 rounded-lg bg-red-50 hover:bg-red-500 text-red-600 hover:text-white transition-all text-sm font-bitter border border-red-100" data-id="<%= c.id %>" title="Eliminar contacto">
                                <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                </svg>
                                <span class="hidden sm:inline">Eliminar</span>
                              </button>
                            </div>
                          </div>

                          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 bg-slate-50 rounded-xl p-4 border border-slate-100">
                            <div>
                              <span class="block text-xs font-bold text-slate-700 uppercase tracking-wider mb-1">Teléfono</span>
                              <span class="font-semibold text-slate-800 text-base"><%= c.telefono || '-' %></span>
                            </div>
                            <div>
                              <span class="block text-xs font-bold text-slate-700 uppercase tracking-wider mb-1">Dirección</span>
                              <span class="font-semibold text-slate-800 text-base"><%= c.direccion || '-' %></span>
                            </div>
                          </div>
                        </div>

                        <div class="contacto-form-editar hidden mt-4 pt-4 border-t-2 border-dashed border-slate-200">
                          <p class="text-sm font-bold text-slate-800 mb-4">Editando información</p>
                          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                              <label class="block text-sm font-semibold text-slate-700 mb-2">Nombre</label>
                              <input type="text" class="edit-nombre w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-base text-slate-800 focus:bg-white focus:ring-4 focus:ring-orange-50 focus:border-orange-400 outline-none transition-all" value="<%= c.nombre %>">
                            </div>
                            <div>
                              <label class="block text-sm font-semibold text-slate-700 mb-2">Relación</label>
                              <input type="text" class="edit-relacion w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-base text-slate-800 focus:bg-white focus:ring-4 focus:ring-orange-50 focus:border-orange-400 outline-none transition-all" value="<%= c.relacion || '' %>">
                            </div>
                            <div>
                              <label class="block text-sm font-semibold text-slate-700 mb-2">Teléfono</label>
                              <input type="tel" class="edit-telefono w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-base text-slate-800 focus:bg-white focus:ring-4 focus:ring-orange-50 focus:border-orange-400 outline-none transition-all" value="<%= c.telefono || '' %>">
                            </div>
                            <div>
                              <label class="block text-sm font-semibold text-slate-700 mb-2">Dirección</label>
                              <input type="text" class="edit-direccion w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-base text-slate-800 focus:bg-white focus:ring-4 focus:ring-orange-50 focus:border-orange-400 outline-none transition-all" value="<%= c.direccion || '' %>">
                            </div>
                          </div>
                          <div class="flex justify-end gap-3 mt-5">
                            <button class="btn-cancelar-editar-contacto px-5 py-2.5 text-sm font-bitter text-slate-600 border border-slate-200 rounded-xl hover:bg-slate-50 transition-all">Cancelar</button>
                            <button class="btn-confirmar-editar-contacto px-5 py-2.5 text-sm font-bitter text-white bg-colorAzulFundacion rounded-xl hover:bg-slate-900 transition-all shadow-sm active:scale-95" data-id="<%= c.id %>">Guardar cambios</button>
                          </div>
                        </div>
                      </div>
                    <% }) %>
                  <% } else { %>
                    <div class="bg-slate-50 rounded-2xl p-8 text-center border-2 border-dashed border-slate-200">
                      <p class="text-base font-medium text-slate-500" id="sin-contactos">No hay contactos de emergencia registrados.</p>
                    </div>
                  <% } %>
                </div>

                <div id="form-nuevo-contacto" class="hidden mt-6 bg-slate-800 rounded-2xl p-1 shadow-lg">
                  <div class="bg-white rounded-[14px] p-6 md:p-8">
                    <h4 class="text-xl font-bold text-slate-800 mb-6">Agregar Nuevo Contacto</h4>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                      <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-2">Nombre completo *</label>
                        <input type="text" id="nuevo-contacto-nombre" class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-base text-slate-800 focus:bg-white focus:ring-4 focus:ring-orange-50 focus:border-orange-400 outline-none transition-all" placeholder="Ej: María Gómez">
                      </div>
                      <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-2">Relación</label>
                        <input type="text" id="nuevo-contacto-relacion" class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-base text-slate-800 focus:bg-white focus:ring-4 focus:ring-orange-50 focus:border-orange-400 outline-none transition-all" placeholder="Ej: Madre, Hermano, Pareja...">
                      </div>
                      <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-2">Teléfono</label>
                        <input type="tel" id="nuevo-contacto-telefono" class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-base text-slate-800 focus:bg-white focus:ring-4 focus:ring-orange-50 focus:border-orange-400 outline-none transition-all" placeholder="Ej: +54 9 11 1234-5678">
                      </div>
                      <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-2">Dirección</label>
