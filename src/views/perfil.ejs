              </div>
            <span class="text-lg font-bold text-slate-800">Cuidado personal</span>
          </div>
          <svg class="accordion-chevron w-6 h-6 text-slate-400 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="accordion-content hidden px-6 pb-8 pt-2">
          <form id="form-cuidado-personal" class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="md:col-span-2">
                <label for="tipoMovilidadSelect" class="block text-sm font-semibold text-slate-700 mb-2">Tipo de movilidad</label>
                <select id="tipoMovilidadSelect" name="tipoMovilidad"
                  class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-base text-slate-800 focus:bg-white focus:ring-4 focus:ring-violet-50 focus:border-violet-400 outline-none transition-all cursor-pointer">
                  <option value="">Seleccioná una opción...</option>
                  <option value="Independiente" <%= locals.cuidadoPersonal?.tipoMovilidad === 'Independiente' ? 'selected' : '' %>>Independiente</option>
                  <option value="Silla de ruedas" <%= locals.cuidadoPersonal?.tipoMovilidad === 'Silla de ruedas' ? 'selected' : '' %>>Silla de ruedas</option>
                  <option value="Bastón" <%= locals.cuidadoPersonal?.tipoMovilidad === 'Bastón' ? 'selected' : '' %>>Bastón</option>
                  <option value="Andador" <%= locals.cuidadoPersonal?.tipoMovilidad === 'Andador' ? 'selected' : '' %>>Andador</option>
                </select>
              </div>
              <% [
                { name: 'cuidadoPersonal', label: 'Asistencia en cuidado personal', placeholder: 'Describí si necesitás ayuda para vestirte, higienizarte...' },
                { name: 'usoBano', label: 'Uso del baño', placeholder: 'Cómo necesitás ayuda en el baño' },
                { name: 'maneraParaComer', label: 'Manera para comer', placeholder: 'Cómo preferís o necesitás comer' },
                { name: 'maneraParaBeber', label: 'Manera para beber', placeholder: 'Cómo preferís o necesitás beber' },
                { name: 'miSeguridad', label: 'Mi seguridad', placeholder: 'Qué necesitás para sentirte seguro/a físicamente' },
                { name: 'rutinaDescanso', label: 'Rutina de descanso', placeholder: 'Describí tu rutina para dormir y descansar' },
                { name: 'problemasVistaAudicion', label: 'Problemas de Vista y/o Audición', placeholder: 'Menciona si utilizás anteojos, audífonos, etc.' }
              ].forEach(campo => { %>
                <div>
                  <label class="block text-sm font-semibold text-slate-700 mb-2"><%= campo.label %></label>
                  <textarea name="<%= campo.name %>" rows="3"
                    class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-base text-slate-800 focus:bg-white focus:ring-4 focus:ring-violet-50 focus:border-violet-400 outline-none transition-all resize-none"
                    placeholder="<%= campo.placeholder %>"><%= locals.cuidadoPersonal?.[campo.name] || '' %></textarea>
                </div>
              <% }) %>
            </div>
            <div class="flex justify-end pt-6">
              <button type="submit" class="btn-guardar w-full md:w-auto px-8 py-3.5 bg-colorAzulFundacion hover:bg-slate-900 text-white text-base font-bitter rounded-xl transition-all shadow-md active:scale-95">
                Guardar cuidados
              </button>
            </div>
          </form>
        </div>
      </div>

      <div class="accordion-item bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden transition-all hover:border-slate-300">
