            <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-6">

                <div class="flex items-center gap-3">

                      <div class="w-12 h-12  rounded-lg bg-indigo-50 flex items-center justify-center border border-indigo-100 shrink-0">
                          <img src="/img/medicacionsin.png" alt="Ícono de medicamentos" class="w-12 h-12 object-contain">
                      </div>

                      <h2 class="text-xl font-bold text-slate-800">Medicación actual</h2>
                    </div>
              <button id="btn-agregar-medicamento" class="w-full sm:w-auto px-5 py-2.5 bg-colorAzulFundacion text-white font-bitter border border-indigo-100 rounded-xl hover:bg-slate-900 transition-all flex items-center justify-center gap-2">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                Agregar medicamento
              </button>
            </div>

