                  <label for="tieneEpilepsia" class="text-base font-bold text-slate-800 cursor-pointer select-none">El paciente tiene epilepsia</label>
                </div>
                <div id="campo-tipo-crisis" class="mt-4 <%= locals.historial?.tieneEpilepsia ? '' : 'hidden' %>">
                  <label class="block text-sm font-semibold text-slate-700 mb-2">Tipo de crisis</label>
                  <input type="text" name="tipoCrisis" value="<%= locals.historial?.tipoCrisis || '' %>"
                    class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-white text-base text-slate-800 focus:ring-4 focus:ring-red-50 focus:border-red-400 outline-none transition-all"
                    placeholder="Describí el tipo de crisis que suele presentar">
                </div>
              </div>

              <div class="bg-slate-50 rounded-2xl p-5 border border-slate-200">
                <div class="flex items-center gap-3">
                    <input type="checkbox" id="tieneOtrasCrisis" name="tieneOtrasCrisis" <%= locals.historial?.tieneOtrasCrisis ? 'checked' : '' %>
                    class="w-5 h-5 rounded border-slate-300 text-slate-800 focus:ring-slate-400 cursor-pointer">
                    <label for="tieneOtrasCrisis" class="text-base font-bold text-slate-800 cursor-pointer select-none">¿Tiene otro tipo de crisis? (Sensoriales, conductuales, etc.)</label>
                </div>
                <div id="campo-otras-crisis" class="mt-4 <%= locals.historial?.tieneOtrasCrisis ? '' : 'hidden' %>">
                    <label class="block text-sm font-semibold text-slate-700 mb-2">Descripción de la crisis</label>
                    <textarea name="descripcionOtrasCrisis" rows="2"
                    class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-white text-base text-slate-800 focus:ring-4 focus:ring-red-50 focus:border-red-400 outline-none transition-all resize-none"
                    placeholder="Describí cómo son estas crisis y qué las desencadena..."><%= locals.historial?.descripcionOtrasCrisis || '' %></textarea>
                    </div>
                </div>

                <div>
                  <label class="block text-sm font-semibold text-slate-700 mb-2">Manera de darme la medicacion</label>
                  <textarea name="posicionAdministracion" rows="3"
                    class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-base text-slate-800 focus:bg-white focus:ring-4 focus:ring-red-50 focus:border-red-400 outline-none transition-all resize-none"
                    placeholder="Manera de tomar la medicacion: sentado, de pie, acostado"><%= locals.historial?.posicionAdministracion || '' %></textarea>
                </div>

              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Datos extras</label>
                <textarea name="datosExtras" rows="3"
                  class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-base text-slate-800 focus:bg-white focus:ring-4 focus:ring-red-50 focus:border-red-400 outline-none transition-all resize-none"
                  placeholder="Cualquier información médica adicional relevante"><%= locals.historial?.datosExtras || '' %></textarea>
              </div>
            </div>

            <div class="flex justify-end pt-4">
              <button type="submit" class="btn-guardar w-full md:w-auto px-8 py-3.5 bg-colorAzulFundacion hover:bg-slate-900 text-white text-base font-bitter rounded-xl transition-all shadow-md active:scale-95">
                Guardar historial médico
              </button>
            </div>
          </form>

          <div class="my-10 border-t-2 border-dashed border-slate-200 relative">
            <span class="absolute left-1/2 -translate-x-1/2 -top-3 bg-white px-4 text-xs font-bold text-slate-800 uppercase tracking-widest">Sección de Medicación</span>
          </div>

