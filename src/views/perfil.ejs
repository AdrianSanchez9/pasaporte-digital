                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                  <div class="md:col-span-2 relative">
                    <label class="block text-sm font-semibold text-slate-700 mb-2">Buscar en Catálogo</label>
                    <input type="text" id="med-search" autocomplete="off"
                      class="w-full px-4 py-3.5 rounded-xl border-2 border-indigo-100 bg-indigo-50/30 text-base text-slate-800 font-medium focus:bg-white focus:ring-4 focus:ring-indigo-50 focus:border-indigo-400 outline-none transition-all placeholder:font-normal"
                      placeholder="Escribí el nombre del remedio (ej: Ibuprofeno...)">
                    <input type="hidden" id="med-id" name="medicamentoId">
                    <ul id="med-dropdown" class="absolute z-20 w-full mt-2 bg-white border border-slate-200 rounded-xl shadow-xl max-h-60 overflow-y-auto hidden"></ul>
                    <p class="text-xs font-medium text-slate-500 mt-2">💡 Si no está en la lista, dejá el nombre escrito y se guardará como personalizado.</p>
                  </div>

                  <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-2">Dosis</label>
                    <input type="text" id="med-dosis" class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-base text-slate-800 focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-500 outline-none transition-all" placeholder="Ej: 500mg, 1 ampolla...">
                  </div>
                  <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-2">Horarios</label>
                    <input type="text" id="med-horarios" class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-base text-slate-800 focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-500 outline-none transition-all" placeholder="Ej: 8:00hs y 20:00hs">
                  </div>
                  <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-2">Forma del medicamento</label>
                    <input type="text" id="med-forma" class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-base text-slate-800 focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-500 outline-none transition-all" placeholder="Ej: Comprimido, Jarabe, Gotas...">
                  </div>
                  <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-2">Momento de ingesta</label>
                    <input type="text" id="med-momento" class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-base text-slate-800 focus:bg-white focus:ring-4 focus:ring-slate-100 focus:border-slate-500 outline-none transition-all" placeholder="Ej: Después de comer, en ayunas...">
                  </div>
                </div>

                <div class="flex flex-col-reverse sm:flex-row justify-end gap-3 mt-8 pt-6 border-t border-slate-100">
                  <button id="btn-cancelar-medicamento" class="px-6 py-3.5 text-base font-bitter text-slate-600 border-2 border-slate-200 rounded-xl hover:bg-slate-50 transition-all">Cancelar</button>
                  <button id="btn-confirmar-medicamento" class="px-6 py-3.5 text-base font-bitter text-white bg-colorAzulFundacion hover:bg-slate-900 rounded-xl transition-all shadow-md shadow-indigo-200 active:scale-95">Guardar en el historial</button>
                </div>
              </div>
            </div>

          </div> </div>
      </div>

      <div class="accordion-item bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden transition-all hover:border-slate-300">
