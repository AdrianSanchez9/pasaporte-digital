        <button class="accordion-trigger w-full flex items-center justify-between px-6 py-6 text-left focus:outline-none focus:bg-slate-50">
          <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl bg-white flex items-center justify-center border border-violet-100 overflow-hidden">
                <img src="/img/emocionsin.png" alt="Ícono de emociones y gustos" class="w-12 h-12 object-contain drop-shadow-sm">
              </div>
            <span class="text-lg font-bold text-slate-800">Emociones y gustos</span>
          </div>
          <svg class="accordion-chevron w-6 h-6 text-slate-400 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="accordion-content hidden px-6 pb-8 pt-2">
          <form id="form-emociones" class="space-y-6">
            <div class="mb-4">
              <p class="text-sm font-medium text-slate-500">Esta información ayuda al personal a interpretar tu estado de ánimo o incomodidad durante la atención médica.</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <% [
                { name: 'descripcionAnsioso', label: 'Cuando estoy ansioso/a', placeholder: 'Ej: Me muevo mucho, me froto las manos...' },
                { name: 'descripcionDolor', label: 'Cuando tengo dolor', placeholder: 'Ej: Lloro, aprieto los dientes, me aíslo...' },
                { name: 'descripcionAsustado', label: 'Cuando estoy asustado/a', placeholder: 'Ej: Busco a mi acompañante, grito...' },
                { name: 'descripcionEnojado', label: 'Cuando estoy enojado/a', placeholder: 'Ej: Frunzo el ceño, no quiero hablar...' },
                { name: 'loQueMeGusta', label: 'Me gusta, por favor hagan esto:', placeholder: 'Lo que me gusta Ej: mirar la tv, leer, música, etc.' },
                { name: 'loQueNoMeGusta', label: 'No me gusta, por favor no me hagan esto:', placeholder: 'Lo que no quiero que me hagan Ej: los gritos, contacto fisico, etc.' }
              ].forEach(campo => { %>
                <div>
                  <label class="block text-sm font-semibold text-slate-700 mb-2"><%= campo.label %></label>
                  <textarea name="<%= campo.name %>" rows="3"
                    class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-base text-slate-800 focus:bg-white focus:ring-4 focus:ring-pink-50 focus:border-pink-400 outline-none transition-all resize-none"
                    placeholder="<%= campo.placeholder %>"><%= locals.emociones?.[campo.name] || '' %></textarea>
                </div>
              <% }) %>
            </div>
            <div class="flex justify-end pt-6">
              <button type="submit" class="btn-guardar w-full md:w-auto px-8 py-3.5 bg-colorAzulFundacion hover:bg-slate-900 text-white text-base font-bitter rounded-xl transition-all shadow-md active:scale-95">
                Guardar emociones
              </button>
            </div>
          </form>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
// ── Acordeones ─────────────────────────────────────────
document.querySelectorAll('.accordion-trigger').forEach(trigger => {
  trigger.addEventListener('click', () => {
    const content = trigger.nextElementSibling;
    const chevron = trigger.querySelector('.accordion-chevron');
    const isOpen = !content.classList.contains('hidden');

    // Cerrar todos
    document.querySelectorAll('.accordion-content').forEach(c => c.classList.add('hidden'));
    document.querySelectorAll('.accordion-chevron').forEach(c => c.classList.remove('rotate-180'));

    if (!isOpen) {
      content.classList.remove('hidden');
      chevron.classList.add('rotate-180');
    }
  });
});

// ── Toast ──────────────────────────────────────────────
function showToast(mensaje, tipo = 'ok') {
  const toast = document.getElementById('toast');
  toast.textContent = mensaje;
  toast.className = `fixed top-6 right-6 z-50 px-5 py-3 rounded-2xl shadow-lg text-sm font-medium transition-all ${
    tipo === 'ok' ? 'bg-slate-800 text-white' : 'bg-red-500 text-white'
  }`;
  toast.classList.remove('hidden');
  setTimeout(() => toast.classList.add('hidden'), 3000);
}

// ── Toggle contraseña ──────────────────────────────────
document.querySelectorAll('.toggle-password').forEach(btn => {
  btn.addEventListener('click', () => {
    const input = btn.previousElementSibling || btn.parentElement.querySelector('input');
    const abierto = btn.querySelector('.ojo-abierto');
    const cerrado = btn.querySelector('.ojo-cerrado');
    const esPassword = input.type === 'password';
    input.type = esPassword ? 'text' : 'password';
    abierto.classList.toggle('hidden', esPassword);
    cerrado.classList.toggle('hidden', !esPassword);
  });
});

// ── Epilepsia toggle ───────────────────────────────────
document.getElementById('tieneEpilepsia')?.addEventListener('change', function() {
  document.getElementById('campo-tipo-crisis').classList.toggle('hidden', !this.checked);
});

document.getElementById('tieneOtrasCrisis')?.addEventListener('change', function() {
  document.getElementById('campo-otras-crisis').classList.toggle('hidden', !this.checked);
});

// ── Médico de cabecera: editar / cancelar ──────────────
const btnEditarMedico = document.getElementById('btn-editar-medico');
const btnCancelarMedico = document.getElementById('btn-cancelar-medico');
const formMedico = document.getElementById('form-medico-cabecera');

if (btnEditarMedico) {
  btnEditarMedico.addEventListener('click', () => formMedico.classList.remove('hidden'));
}
if (btnCancelarMedico) {
  btnCancelarMedico.addEventListener('click', () => formMedico.classList.add('hidden'));
}

// ── Medicamentos: agregar / cancelar ──────────────────
document.getElementById('btn-agregar-medicamento')?.addEventListener('click', () => {
  document.getElementById('form-agregar-medicamento-wrapper').classList.remove('hidden');
});
document.getElementById('btn-cancelar-medicamento')?.addEventListener('click', () => {
  document.getElementById('form-agregar-medicamento-wrapper').classList.add('hidden');
});

// ── Medicamentos: Autocompletado ───────────────────────
const searchInput = document.getElementById('med-search');
const hiddenInput = document.getElementById('med-id');
const dropdown = document.getElementById('med-dropdown');
let timeoutId;

if (searchInput) {
  searchInput.addEventListener('input', (e) => {
    const query = e.target.value.trim();
    hiddenInput.value = ''; // Limpiamos el ID oculto si el usuario borra/cambia el texto

    if (query.length < 2) {
      dropdown.classList.add('hidden');
      return;
    }

    clearTimeout(timeoutId);
    timeoutId = setTimeout(async () => {
      try {
        const res = await fetch(`/medicamentos?search=${encodeURIComponent(query)}`);
        const medicamentos = await res.json();
        dropdown.innerHTML = '';

        if (medicamentos.length === 0) {
          dropdown.innerHTML = `<li class="px-4 py-3 text-sm text-slate-500">No se encontraron resultados en el catálogo. Quedará como personalizado.</li>`;
        } else {
          medicamentos.forEach(med => {
            const li = document.createElement('li');
            li.className = 'px-4 py-2.5 text-sm text-slate-700 hover:bg-slate-50 cursor-pointer border-b border-slate-50 last:border-0';
            li.textContent = med.nombre;

            li.addEventListener('click', () => {
              searchInput.value = med.nombre;
              hiddenInput.value = med.id;
              dropdown.classList.add('hidden');
            });
            dropdown.appendChild(li);
          });
        }
        dropdown.classList.remove('hidden');
      } catch (error) {
        console.error('Error buscando medicamentos', error);
      }
    }, 300);
  });

  document.addEventListener('click', (e) => {
    if (!searchInput.contains(e.target) && !dropdown.contains(e.target)) {
      dropdown.classList.add('hidden');
    }
  });
}

// ── Confirmar y Guardar Medicamento ─────────────────────────────────
document.getElementById('btn-confirmar-medicamento')?.addEventListener('click', async () => {
  const medicamentoId = document.getElementById('med-id').value;
  const textoBuscador = document.getElementById('med-search').value.trim();

  if (!medicamentoId && !textoBuscador) {
    return showToast('Por favor, seleccioná o escribí el nombre del medicamento', 'error');
  }

  const historialId = '<%= locals.historial?.id || "" %>';
  const pacienteId = '<%= locals.paciente?.userId || "" %>';

  const bodyData = {
    dosis: document.getElementById('med-dosis').value,
    horarios: document.getElementById('med-horarios').value,
    formaMedicamento: document.getElementById('med-forma').value,
    momentoIngesta: document.getElementById('med-momento').value,
  };

  if (medicamentoId) {
    bodyData.medicamentoId = medicamentoId;
  } else {
    bodyData.medicamentoPersonalizado = textoBuscador;
  }

  Object.keys(bodyData).forEach(key => {
    if (bodyData[key] === '') {
      delete bodyData[key];
    }
  });

  try {
    const res = await fetch(`/historial/${pacienteId}/medicamentos`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(bodyData)
    });

    if (!res.ok) {
       const err = await res.json();
       throw new Error(err.mensaje || 'Error al guardar');
    }

    showToast('Medicamento agregado al historial');
    setTimeout(() => location.reload(), 1200);
  } catch (error) {
    showToast(error.message, 'error');
  }
});

document.querySelectorAll('.btn-eliminar-medicamento').forEach(btn => {
  btn.addEventListener('click', async () => {
    const medId = btn.dataset.id;
    const pacienteId = '<%= locals.paciente?.userId || "" %>';

    if (!confirm('¿Eliminar este medicamento?')) return;

    try {
      const res = await fetch(`/historial/${pacienteId}/medicamentos/${medId}`, { method: 'DELETE' });
      if (!res.ok) throw new Error();
      btn.closest('.medicamento-item').remove();
      showToast('Medicamento eliminado');

      // Si ya no quedan medicamentos, mostramos el texto de vacío
      const lista = document.getElementById('lista-medicamentos');
      if (lista.querySelectorAll('.medicamento-item').length === 0) {
        lista.innerHTML = `
          <div class="bg-slate-50 rounded-xl p-6 text-center border border-slate-100">
            <p class="text-sm text-slate-500" id="sin-medicamentos">El paciente no tiene medicamentos registrados.</p>
          </div>
        `;
      }
    } catch {
      showToast('Error al eliminar', 'error');
    }
  });
});

const pacienteId = '<%= locals.paciente?.userId ?? "" %>';

const endpoints = {
  'form-datos-personales':  { url: `/pacientes/${pacienteId}`,  method: 'PUT' },
  'form-historial':         { url: `/historial/${pacienteId}`,  method: 'PUT' },
  'form-cuidado-personal':  { url: `/perfil-paciente/${pacienteId}/cuidado-personal`,method: 'PUT' },
  'form-comunicacion':      { url: `/perfil-paciente/${pacienteId}/perfil-comunicacion`,method: 'PUT' },
  'form-emociones':         { url: `/perfil-paciente/${pacienteId}/emociones`, method: 'PUT' },
};

Object.entries(endpoints).forEach(([formId, config]) => {
  const form = document.getElementById(formId);
  if (!form) return;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('.btn-guardar');
    const textoOriginal = btn.textContent;
    btn.textContent = 'Guardando...';
    btn.disabled = true;

    const data = Object.fromEntries(new FormData(form).entries());

    // LIMPIEZA PARA QUE ZOD NO EXPLOTE CON CAMPOS OPCIONALES VACÍOS
    Object.keys(data).forEach(key => {
      if (data[key] === '') {
        delete data[key];
      }
    });

    if (formId === 'form-historial') {
      const checkEpilepsia = document.getElementById('tieneEpilepsia');
      if (checkEpilepsia) data.tieneEpilepsia = checkEpilepsia.checked;
    }

    if (formId === 'form-historial') {
      const checkOtraCrisis = document.getElementById('tieneOtrasCrisis');
      if (checkOtraCrisis) data.tieneOtrasCrisis = checkOtraCrisis.checked;
    }

    try {
      const res = await fetch(config.url, {
        method: config.method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });

      if (!res.ok) {
        const errorDelBackend = await res.json();
        console.error("Rebotado por el backend:", errorDelBackend);
        throw new Error(errorDelBackend.mensaje || errorDelBackend.error || 'Datos inválidos');
      }

      showToast('Cambios guardados correctamente');
    } catch (error) {
      showToast(error.message, 'error');
    } finally {
      btn.textContent = textoOriginal;
      btn.disabled = false;
    }
  });
});

// ── Médico de cabecera (POST / PATCH) ──────────────────────────────
const formMedicoCabecera = document.getElementById('form-medico-cabecera');
if (formMedicoCabecera) {
  formMedicoCabecera.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;
    const medicoId = form.dataset.medicoId;
    const btn = form.querySelector('.btn-guardar');
    const textoOriginal = btn.textContent;
    btn.textContent = 'Guardando...';
    btn.disabled = true;

    const data = Object.fromEntries(new FormData(form).entries());
    const url = medicoId ? `/pacientes/mi-medico-cabecera${medicoId}` : '/pacientes/mi-medico-cabecera';
    const method = medicoId ? 'PUT' : 'POST';


    Object.keys(data).forEach(key => {
      if (data[key] === '') {
        delete data[key];
      }
    });

    try {
      const res = await fetch(`/pacientes/mi-medico-cabecera`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      console.log(res)
      if (!res.ok) {
        const errorDelBackend = await res.json();
        throw new Error(errorDelBackend.mensaje || 'Error al guardar el médico');
      }

      showToast('Médico guardado correctamente');
      setTimeout(() => location.reload(), 1200);
    } catch (error) {
      showToast(error.message, 'error');
    } finally {
      btn.textContent = textoOriginal;
      btn.disabled = false;
    }
  });
}


document.getElementById('btn-agregar-contacto').addEventListener('click', () => {
  document.getElementById('form-nuevo-contacto').classList.remove('hidden');
});
document.getElementById('btn-cancelar-contacto').addEventListener('click', () => {
  document.getElementById('form-nuevo-contacto').classList.add('hidden');
});

// Agregar contacto
document.getElementById('btn-confirmar-contacto').addEventListener('click', async () => {
  const nombre = document.getElementById('nuevo-contacto-nombre').value.trim();
  if (!nombre) return showToast('El nombre es obligatorio', 'error');

  try {
    const res = await fetch('/pacientes/mis-contactos', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        nombre,
        relacion: document.getElementById('nuevo-contacto-relacion').value,
        telefono: document.getElementById('nuevo-contacto-telefono').value,
        direccion: document.getElementById('nuevo-contacto-direccion').value,
      })
    });
    if (!res.ok) throw new Error();
    showToast('Contacto agregado');
    document.getElementById('form-nuevo-contacto').classList.add('hidden');
    setTimeout(() => location.reload(), 1200);
  } catch {
    showToast('Error al agregar contacto', 'error');
  }
});

// Editar / cancelar edición
document.querySelectorAll('.btn-editar-contacto').forEach(btn => {
  btn.addEventListener('click', () => {
    const item = btn.closest('.contacto-item');
    item.querySelector('.contacto-vista').classList.add('hidden');
    item.querySelector('.contacto-form-editar').classList.remove('hidden');
  });
});

document.querySelectorAll('.btn-cancelar-editar-contacto').forEach(btn => {
  btn.addEventListener('click', () => {
    const item = btn.closest('.contacto-item');
    item.querySelector('.contacto-vista').classList.remove('hidden');
    item.querySelector('.contacto-form-editar').classList.add('hidden');
  });
});

// Confirmar edición
document.querySelectorAll('.btn-confirmar-editar-contacto').forEach(btn => {
  btn.addEventListener('click', async () => {
    const contactoId = btn.dataset.id;
    const item = btn.closest('.contacto-item');

    try {
      const res = await fetch(`/pacientes/mis-contactos/${contactoId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          nombre: item.querySelector('.edit-nombre').value,
          relacion: item.querySelector('.edit-relacion').value,
          telefono: item.querySelector('.edit-telefono').value,
          direccion: item.querySelector('.edit-direccion').value,
        })
      });
      if (!res.ok) throw new Error();
      showToast('Contacto actualizado');
      setTimeout(() => location.reload(), 1200);
    } catch {
      showToast('Error al actualizar contacto', 'error');
    }
  });
});

// Eliminar contacto
document.querySelectorAll('.btn-eliminar-contacto').forEach(btn => {
  btn.addEventListener('click', async () => {
    const contactoId = btn.dataset.id;
    if (!confirm('¿Eliminar este contacto?')) return;
    try {
      const res = await fetch(`/pacientes/mis-contactos/${contactoId}`, { method: 'DELETE' });
      if (!res.ok) throw new Error();
      btn.closest('.contacto-item').remove();
      showToast('Contacto eliminado');
    } catch {
      showToast('Error al eliminar contacto', 'error');
    }
  });
});


document.getElementById('selectReligion').addEventListener('change', function() {
  const input = document.getElementById('religionPersonalizada');
  if (this.value === 'Otra') {
    input.classList.remove('hidden');
    input.required = true;
  } else {
    input.classList.add('hidden');
    input.required = false;
    input.value = '';
  }
});
</script>
