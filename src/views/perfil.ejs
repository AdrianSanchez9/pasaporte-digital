                <% locals.historial.medicamentos.forEach(med => { %>
                  <div class="medicamento-item relative bg-white rounded-2xl p-5 md:p-6 border border-slate-200 shadow-sm hover:shadow-md transition-shadow" data-id="<%= med.id %>">

                    <div class="flex justify-between items-start mb-5">
                      <h3 class="text-lg font-extrabold text-slate-800 flex items-center gap-2">
                         <%= med.medicamento?.nombre || med.medicamentoPersonalizado || 'Sin nombre' %>
                      </h3>
                      <button class="btn-eliminar-medicamento group flex items-center gap-2 px-3 py-1.5 rounded-lg bg-red-50 hover:bg-red-500 text-red-600 hover:text-white transition-all text-sm font-bitter border border-red-100" data-id="<%= med.id %>" title="Eliminar medicamento">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                        <span class="hidden sm:inline">Eliminar</span>
                      </button>
                    </div>

                    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 bg-slate-50 rounded-xl p-4 border border-slate-100">
                      <div>
                        <span class="block text-xs font-bold text-slate-700 uppercase tracking-wider mb-1">Dosis</span>
                        <span class="font-semibold text-slate-800 text-base"><%= med.dosis || '-' %></span>
                      </div>
                      <div>
                        <span class="block text-xs font-bold text-slate-700 uppercase tracking-wider mb-1">Forma</span>
                        <span class="font-semibold text-slate-800 text-base"><%= med.formaMedicamento || '-' %></span>
                      </div>
                      <div>
                        <span class="block text-xs font-bold text-slate-700 uppercase tracking-wider mb-1">Horarios</span>
                        <span class="font-semibold text-slate-800 text-base"><%= med.horarios || '-' %></span>
                      </div>
                      <div class="col-span-2 md:col-span-1">
                        <span class="block text-xs font-bold text-slate-700 uppercase tracking-wider mb-1">Ingesta</span>
                        <span class="font-semibold text-slate-800 text-base"><%= med.momentoIngesta || '-' %></span>
                      </div>
                    </div>

                  </div>
                <% }) %>
              <% } else { %>
                <div class="bg-slate-50 rounded-2xl p-8 text-center border-2 border-dashed border-slate-200">
                  <p class="text-base font-medium text-slate-500" id="sin-medicamentos">El paciente no tiene medicamentos registrados.</p>
                </div>
              <% } %>
            </div>

            <div id="form-agregar-medicamento-wrapper" class="hidden mt-6 bg-slate-800 rounded-2xl p-1 shadow-lg">
              <div class="bg-white rounded-[14px] p-6 md:p-8">
