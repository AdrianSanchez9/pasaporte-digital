<header class="bg-white border-b border-slate-200 sticky top-0 z-50 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-16 items-center">

      <div class="flex-shrink-0 flex items-center">
        <a href="/" class="text-xl font-semibold text-slate-800 tracking-tight">Pasaporte Médico</a>
      </div>

      <nav class="hidden md:flex space-x-8">
        <% if (locals.user) { %>
          <a href="/" class="text-slate-500 hover:text-slate-900 px-3 py-2 text-sm font-medium transition-colors">Inicio</a>
        <% } %>

        <% if (locals.user && locals.user.rolNombre === 'PACIENTE') { %>
          <a href="/perfil" class="text-slate-500 hover:text-slate-900 px-3 py-2 text-sm font-medium transition-colors">Mi Perfil</a>
          <a href="/historial" class="text-slate-500 hover:text-slate-900 px-3 py-2 text-sm font-medium transition-colors">Historial</a>
          <a href="/qr" class="text-slate-500 hover:text-slate-900 px-3 py-2 text-sm font-medium transition-colors">Mi QR</a>
        <% } %>

        <% if (locals.user && (locals.user.rolNombre === 'MEDICO' || locals.user.rolNombre === 'ENFERMERO')) { %>
          <a href="/pacientes" class="text-slate-500 hover:text-slate-900 px-3 py-2 text-sm font-medium transition-colors">Pacientes</a>
          <a href="/escanear" class="text-slate-500 hover:text-slate-900 px-3 py-2 text-sm font-medium transition-colors">Escanear QR</a>
        <% } %>

        <% if (locals.user && locals.user.rolNombre === 'ADMIN') { %>
          <a href="/admin/usuarios" class="text-slate-500 hover:text-slate-900 px-3 py-2 text-sm font-medium transition-colors">Usuarios</a>
          <a href="/auth/registro" class="text-slate-500 hover:text-slate-900 px-3 py-2 text-sm font-medium transition-colors">Registrar usuarios</a>
        <% } %>
      </nav>

      <div class="flex items-center space-x-6">
        <% if (locals.user && locals.user.nombre) { %>
          <div class="text-sm text-slate-600 hidden sm:block text-right">
            <span class="font-medium text-slate-800 block"><%= locals.user.nombre %> <%= locals.user.apellido %></span>
          </div>
          <button id="logoutBtn" class="text-sm font-medium text-slate-500 hover:text-red-600 transition-colors">Salir</button>
        <% } else { %>
          <a href="/auth/login" class="text-sm font-medium text-blue-600 hover:text-blue-800 transition-colors">Iniciar Sesión</a>
        <% } %>
      </div>

    </div>
  </div>
</header>

<script>
  // Script para manejar el cierre de sesión
  document.getElementById('logoutBtn')?.addEventListener('click', async (e) => {
    e.preventDefault();
    if (confirm('¿Cerrar sesión?')) {
      try {
        const res = await fetch('/auth/logout', { method: 'POST' });
        if (res.ok) window.location.href = '/auth/login';
      } catch (error) {
        console.error('Error al salir');
      }
    }
  });
</script>
